<%
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('terms', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-24">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.title %>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>
        <div class="mt-6 text-sm text-gray-500">
            <%= t.hero.lastUpdatedLabel %> <%= t.hero.lastUpdatedDate %>
        </div>
    </div>
</section>

<!-- Main Content Section -->
<section class="relative bg-surface-primary py-16 sm:py-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 top-1/4 right-0 opacity-10"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 bottom-1/4 left-0 opacity-10"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Introduction Card -->
        <div class="card card--glow mb-12 animate-on-scroll">
            <div class="prose prose-invert prose-lg max-w-none">
                <p class="text-gray-300 leading-relaxed"><%- t.intro.p1Html %></p>
                <p class="text-gray-300 leading-relaxed"><%- t.intro.p2Html %></p>
                <p class="text-gray-300 leading-relaxed font-semibold"><%- t.intro.p3Html %></p>
                <p class="text-gray-300 leading-relaxed"><%- t.intro.p4Html %></p>
            </div>
        </div>

        <% t.sections.forEach(function (s) { %>
        <div class="mb-12 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= s.title %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <div class="card card--glow">
                <div class="prose prose-invert prose-lg max-w-none">
                    <% if (s.lead) { %>
                    <p class="text-gray-300"><%= s.lead %></p>
                    <% } %>

                    <% if (s.items && s.items.length) { %>
                    <ul class="text-gray-300 space-y-2">
                        <% s.items.forEach(function (it) { %>
                        <li><%- it %></li>
                        <% }); %>
                    </ul>
                    <% } %>

                    <% if (s.paragraphs && s.paragraphs.length) { %>
                        <% s.paragraphs.forEach(function (p) { %>
                        <p class="text-gray-300"><%- p %></p>
                        <% }); %>
                    <% } %>

                    <% if (s.prohibitedList && s.prohibitedList.length) { %>
                    <ul class="text-gray-300 space-y-1">
                        <% s.prohibitedList.forEach(function (li) { %>
                        <li><%- li %></li>
                        <% }); %>
                    </ul>
                    <% } %>

                    <% if (s.paragraphsAfter && s.paragraphsAfter.length) { %>
                        <% s.paragraphsAfter.forEach(function (p) { %>
                        <p class="text-gray-300"><%- p %></p>
                        <% }); %>
                    <% } %>

                    <% if (s.contactItems && s.contactItems.length) { %>
                    <ul class="text-gray-300 space-y-2">
                        <% s.contactItems.forEach(function (ci) { %>
                        <li><%- ci %></li>
                        <% }); %>
                    </ul>
                    <% } %>
                </div>
            </div>
        </div>
        <% }); %>
    </div>
</section>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
