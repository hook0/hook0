<%
// Data-driven page: see scripts/build-i18n + locales/index.js for the engine.
// Object.assign at the very top resets every page-meta key from locale strings,
// killing the shared-locals bleed, and binds `t` to this page's strings.
// Runs BEFORE any output so <html lang> sees pageLang.
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('self-hosted-webhooks', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.titleLine1 %>
            <span class="block text-gradient-green"><%= t.hero.titleLine2 %></span>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group" onclick="trackEvent('CTA', 'Click', '<%= t.hero.ctaPrimaryTrack %>')">
                <%= t.hero.ctaPrimary %>
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </a>
            <a href="<%= t.hero.ctaSecondaryHref %>" class="btn btn--secondary btn--lg" onclick="trackEvent('CTA', 'Click', '<%= t.hero.ctaSecondaryTrack %>')">
                <%= t.hero.ctaSecondary %>
            </a>
        </div>

        <!-- Trust Indicators -->
        <div class="mt-10 flex flex-wrap gap-6 justify-center text-sm text-gray-400 animate-on-scroll">
            <% t.hero.trustIndicators.forEach(function (ind) { %>
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span><%= ind %></span>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<% if (t.socialProof) { %>
<%- include('./includes/_social-proof-bar.ejs') %>
<% } %>

<!-- Why Self-Host -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 top-1/4 right-0 opacity-10"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.whySelfHost.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.whySelfHost.h2 %></h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 stagger-children">
            <% t.whySelfHost.cards.forEach(function (c, i) { %>
            <% var iconBg = (i % 2 === 0) ? 'bg-green-500/10 border-green-500/20' : 'bg-indigo-500/10 border-indigo-500/20'; %>
            <% var iconColor = (i % 2 === 0) ? 'text-green-400' : 'text-indigo-400'; %>
            <div class="animate-on-scroll card card--glow p-8">
                <div class="w-12 h-12 rounded-xl <%= iconBg %> border flex items-center justify-center mb-6">
                    <% if (c.icon === 'shield') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                    <% } else if (c.icon === 'code') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                    </svg>
                    <% } else if (c.icon === 'server') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"></path>
                    </svg>
                    <% } else if (c.icon === 'sync') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                    </svg>
                    <% } %>
                </div>
                <h3 class="text-xl font-bold text-white mb-3"><%= c.title %></h3>
                <p class="text-gray-400">
                    <%= c.body %>
                </p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Deployment Options -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.deployment.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.deployment.h2 %></h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 stagger-children">
            <% t.deployment.options.forEach(function (o) { %>
            <% var iconBg = (o.kind === 'docker') ? 'bg-blue-500/10 border-blue-500/20' : 'bg-purple-500/10 border-purple-500/20'; %>
            <% var iconColor = (o.kind === 'docker') ? 'text-blue-400' : 'text-purple-400'; %>
            <div class="animate-on-scroll card card--glow p-8">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg <%= iconBg %> border flex items-center justify-center">
                        <% if (o.kind === 'docker') { %>
                        <svg class="w-5 h-5 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                        </svg>
                        <% } else { %>
                        <svg class="w-5 h-5 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                        </svg>
                        <% } %>
                    </div>
                    <h3 class="text-xl font-bold text-white"><%= o.title %></h3>
                </div>
                <p class="text-gray-400 mb-6"><%= o.body %></p>
                <div class="bg-surface-tertiary rounded-lg p-4">
                    <code class="text-sm text-green-400"><%- o.code %></code>
                </div>
                <a href="<%= o.docsHref %>" class="mt-6 inline-flex items-center gap-2 text-sm text-green-400 hover:text-green-300 transition-colors" onclick="trackEvent('CTA', 'Click', '<%= o.docsTrack %>')">
                    <%= o.docsLabel %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </a>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Who Self-Hosts -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 bottom-1/4 left-0 opacity-10"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.whoSelfHosts.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.whoSelfHosts.h2 %></h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6 stagger-children">
            <% t.whoSelfHosts.cards.forEach(function (c, i) { %>
            <% var iconBg = (i % 2 === 0) ? 'bg-green-500/10 border-green-500/20' : 'bg-indigo-500/10 border-indigo-500/20'; %>
            <% var iconColor = (i % 2 === 0) ? 'text-green-400' : 'text-indigo-400'; %>
            <div class="animate-on-scroll card card--glow p-6 text-center">
                <div class="w-12 h-12 rounded-xl <%= iconBg %> border flex items-center justify-center mx-auto mb-4">
                    <% if (c.icon === 'industry') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                    <% } else if (c.icon === 'globe') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.893 13.393l-1.135-1.135a2.252 2.252 0 01-.421-.585l-1.08-2.16a.414.414 0 00-.663-.107.827.827 0 01-.812.21l-1.273-.363a.89.89 0 00-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 01-1.81 1.025 1.055 1.055 0 01-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 01-1.383-2.46l.007-.042a2.25 2.25 0 01.29-.787l.09-.15a2.25 2.25 0 012.37-1.048l1.178.236a1.125 1.125 0 001.302-.795l.208-.73a1.125 1.125 0 00-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 01-1.591.659h-.18c-.249 0-.487.1-.662.274a.931.931 0 01-1.458-1.137l1.411-2.353a2.25 2.25 0 00.286-.76m11.928 9.869A9 9 0 008.965 3.525m11.928 9.868A9 9 0 118.965 3.525"></path>
                    </svg>
                    <% } else if (c.icon === 'lock') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                    </svg>
                    <% } %>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2"><%= c.title %></h3>
                <p class="text-sm text-gray-400"><%= c.body %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.faq.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.faq.h2 %></h2>
        </div>

        <div class="space-y-6 stagger-children">
            <% t.faq.items.forEach(function (f) { %>
            <div class="animate-on-scroll card card--glow p-6">
                <h3 class="text-lg font-semibold text-white mb-2"><%= f.q %></h3>
                <p class="text-gray-400"><%- f.a %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Deep Dive Link -->
<section class="py-12 relative">
    <div class="container mx-auto px-6 text-center">
        <p class="text-gray-400"><%= t.deepDive.prefix %> <a href="<%= t.deepDive.linkHref %>" class="text-indigo-400 hover:text-indigo-300 underline"><%= t.deepDive.linkLabel %></a><%= t.deepDive.suffix %></p>
    </div>
</section>

<!-- Related Pages -->
<section class="py-12 relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-lg font-semibold text-gray-400 mb-6 text-center"><%= t.related.h2 %></h2>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
            <% t.related.links.forEach(function (l) { %>
            <% var href = locals.i18nHelpers ? locals.i18nHelpers.getPath(l.enSlug, locals.pageLang) : ('./' + l.enSlug); %>
            <% if (!href) { href = locals.i18nHelpers ? locals.i18nHelpers.getPath(l.enSlug, 'en') : ('./' + l.enSlug); } %>
            <a href="<%= href %>" class="text-indigo-400 hover:text-indigo-300 underline"><%= l.label %></a>
            <% }); %>
        </div>
    </div>
</section>

<!-- CTA Section -->
<%- include('./includes/_cta-inline.ejs') %>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
