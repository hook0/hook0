<!DOCTYPE html>
<html lang="en">
<head>
    <title>Self-Hosted Webhooks — Docker & Kubernetes | Hook0</title>
    <%
    locals.pageTitle = 'Self-Hosted Webhooks — Docker & Kubernetes | Hook0';
    locals.pageDescription = 'Deploy Hook0 on your infrastructure with Docker or Kubernetes. Fully open-source, same code as cloud. No data leaves your network.';
    locals.pageCanonical = '/self-hosted-webhooks';
    locals.pageFAQSchema = {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can I self-host Hook0?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Hook0 is fully open-source under the SSPL-1.0 license and supports self-hosting via Docker Compose or Kubernetes. The self-hosted version runs the exact same code as the managed cloud service."
          }
        },
        {
          "@type": "Question",
          "name": "Is the self-hosted version the same as the cloud version?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. There is no 'community edition' or feature-gated version. The self-hosted Hook0 runs the exact same codebase as the managed cloud. All features are included."
          }
        },
        {
          "@type": "Question",
          "name": "What infrastructure do I need to self-host Hook0?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hook0 can be deployed with Docker Compose for simple setups or Kubernetes (Helm chart) for production environments. It requires PostgreSQL for storage. Minimum requirements are modest — a single node can handle thousands of events per minute."
          }
        },
        {
          "@type": "Question",
          "name": "Does my data leave my network with self-hosted Hook0?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. With self-hosted Hook0, all data stays on your infrastructure. There is no telemetry, no phone-home, no external dependencies beyond your own network. This makes it ideal for regulated industries and data sovereignty requirements."
          }
        },
        {
          "@type": "Question",
          "name": "Can I try Hook0 before self-hosting?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The Hook0 cloud version offers a free tier with 100 events per day, no credit card required. You can try it out and then deploy on-premise when you are ready."
          }
        }
      ]
    };
    %>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow">Self-Hosted</span>
        <h1 class="mt-4 text-display-xl text-white">
            Self-Hosted
            <span class="block text-gradient-green">Webhook Platform</span>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            Deploy webhooks on-premise with the same codebase as our cloud version. Your webhook payloads never leave your network. Docker Compose or Kubernetes. Open-source under SSPL v1, no vendor lock-in.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group" onclick="trackEvent('CTA', 'Click', 'self-hosted-hero-register')">
                Start Free
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </a>
            <a href="https://documentation.hook0.com/self-hosting/docker-compose" class="btn btn--secondary btn--lg" onclick="trackEvent('CTA', 'Click', 'self-hosted-hero-docs')">
                Installation Guide
            </a>
        </div>

        <!-- Trust Indicators -->
        <div class="mt-10 flex flex-wrap gap-6 justify-center text-sm text-gray-400 animate-on-scroll">
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Same code as cloud</span>
            </div>
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>SSPL-1.0 License</span>
            </div>
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>No telemetry</span>
            </div>
        </div>
    </div>
</section>

<%- include('./includes/_social-proof-bar.ejs') %>

<!-- Why Self-Host -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 top-1/4 right-0 opacity-10"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow">Why Self-Host</span>
            <h2 class="mt-4 text-display font-bold text-white">Your Data, Your Infrastructure</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 stagger-children">
            <div class="animate-on-scroll card card--glow p-8">
                <div class="w-12 h-12 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Data Sovereignty</h3>
                <p class="text-gray-400">
                    On-premise webhooks where payloads stay inside your perimeter. Period. No third-party ever sees your data. CISO-friendly for healthcare, finance, government, and GDPR compliance.
                </p>
            </div>

            <div class="animate-on-scroll card card--glow p-8">
                <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Fully Open-Source</h3>
                <p class="text-gray-400">
                    SSPL-1.0 licensed. No open-core tricks and no feature gates. Every line of code is on GitHub and GitLab. You can audit it, fork it, or send a PR.
                </p>
            </div>

            <div class="animate-on-scroll card card--glow p-8">
                <div class="w-12 h-12 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Docker & Kubernetes</h3>
                <p class="text-gray-400">
                    Docker Compose for dev and small deployments. Helm chart for production Kubernetes clusters. Both work out of the box.
                </p>
            </div>

            <div class="animate-on-scroll card card--glow p-8">
                <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Same Code, Same Features</h3>
                <p class="text-gray-400">
                    One codebase. The binary you deploy is built from the same repo as our cloud. Retries, signatures, monitoring, subscription management: nothing is stripped out.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Deployment Options -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow">Deployment</span>
            <h2 class="mt-4 text-display font-bold text-white">Two Ways to Deploy</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 stagger-children">
            <!-- Docker Compose -->
            <div class="animate-on-scroll card card--glow p-8">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">Docker Compose</h3>
                </div>
                <p class="text-gray-400 mb-6">Good for dev, testing, and small-scale production. Three commands, everything starts.</p>
                <div class="bg-surface-tertiary rounded-lg p-4">
                    <code class="text-sm text-green-400">git clone https://github.com/hook0/hook0.git<br>cd hook0<br>docker compose up -d</code>
                </div>
                <a href="https://documentation.hook0.com/self-hosting/docker-compose" class="mt-6 inline-flex items-center gap-2 text-sm text-green-400 hover:text-green-300 transition-colors" onclick="trackEvent('CTA', 'Click', 'self-hosted-docker-docs')">
                    Docker Compose guide
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </a>
            </div>

            <!-- Kubernetes -->
            <div class="animate-on-scroll card card--glow p-8">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">Kubernetes</h3>
                </div>
                <p class="text-gray-400 mb-6">For production. Horizontal scaling, health checks, rolling updates via Helm.</p>
                <div class="bg-surface-tertiary rounded-lg p-4">
                    <code class="text-sm text-green-400">helm repo add hook0 https://charts.hook0.com<br>helm install hook0 hook0/hook0</code>
                </div>
                <a href="https://documentation.hook0.com/self-hosting/kubernetes" class="mt-6 inline-flex items-center gap-2 text-sm text-green-400 hover:text-green-300 transition-colors" onclick="trackEvent('CTA', 'Click', 'self-hosted-k8s-docs')">
                    Kubernetes guide
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </a>
            </div>
        </div>
    </div>
</section>

