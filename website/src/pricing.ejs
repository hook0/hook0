<!DOCTYPE html>
<html lang="en">
<head>
    <title>Hook0 Pricing — Free Tier, No Credit Card | Webhook Infrastructure</title>
    <%
    locals.pageTitle = 'Hook0 Pricing — Free Tier, No Credit Card | Webhook Infrastructure';
    locals.pageDescription = 'Free forever tier included. Cloud from €59/month, open-source and self-hostable. Compare plans: events/day, subscriptions, data retention, support. No hidden fees.';
    locals.pageCanonical = '/pricing';
    locals.pageNoindex = false;
    locals.pageFAQSchema = {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Is Hook0 free?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Hook0 has a free Developer tier that includes 100 webhook events per day, HMAC signatures, and delivery monitoring. No credit card required. Hook0 is also open-source and self-hostable if you need data sovereignty or specific infrastructure requirements."
          }
        },
        {
          "@type": "Question",
          "name": "How much does Hook0 cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hook0 Cloud plans start at €59/month (Startup) and €190/month (Pro, 20% annual discount available). The Developer tier is free forever. Enterprise pricing is custom."
          }
        },
        {
          "@type": "Question",
          "name": "Can I self-host Hook0 for free?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Hook0 is fully open-source under the SSPL-1.0 license. You can self-host it with Docker Compose or Kubernetes. When self-hosting, you manage your own infrastructure, scaling, updates, and monitoring. Most teams start with Hook0 Cloud for the fastest path to production."
          }
        },
        {
          "@type": "Question",
          "name": "What happens if I exceed my daily event limit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "On the free Developer plan, extra events are blocked. On paid plans (Startup and Pro), extra events are not blocked — they are billed at a per-event rate (€0.003/event on Startup, €0.0001/event on Pro)."
          }
        },
        {
          "@type": "Question",
          "name": "How does Hook0 pricing compare to Svix and Hookdeck?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hook0 Cloud starts at €59/month vs Svix at $490/month for comparable features. Svix locks self-hosting behind enterprise pricing. Hookdeck has no self-hosted option. Hook0 is also fully open-source under SSPL, so you can self-host if you need data sovereignty."
          }
        }
      ]
    };
    %>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero H1 -->
<section class="relative pt-32 pb-8">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-display font-bold text-white">Hook0 Pricing</h1>
        <p class="mt-4 text-xl text-gray-300 max-w-2xl mx-auto">Choose the plan that fits your team. Start free, scale to production.</p>
    </div>
</section>

<%- include('./includes/_pricing.ejs') %>

<!-- Why Hook0 Pricing is Different -->
<section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-surface-primary via-surface-secondary to-surface-primary"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <h2 class="text-heading-xl font-bold text-white">Why Hook0 pricing is different</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
            <div class="animate-on-scroll text-center">
                <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-green-500/10 flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2">Bootstrapped, no VC</h3>
                <p class="text-gray-400 text-sm">No pressure to raise prices. We grow with you, not against you.</p>
            </div>
            <div class="animate-on-scroll text-center">
                <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-indigo-500/10 flex items-center justify-center">
                    <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2">Open-source, no lock-in</h3>
                <p class="text-gray-400 text-sm">Audit every line of code. Self-host for compliance. Start with Cloud for fastest path to production.</p>
            </div>
            <div class="animate-on-scroll text-center">
                <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-orange-500/10 flex items-center justify-center">
                    <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2">No hidden fees</h3>
                <p class="text-gray-400 text-sm">Retries are free. HMAC signatures included. No per-endpoint charges.</p>
            </div>
        </div>
    </div>
</section>

<%- include('./includes/_cta.ejs') %>
<%- include('./includes/_footer.ejs') %>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver(function(entries) {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.animate-on-scroll').forEach(el => {
        observer.observe(el);
    });
});
</script>

</body>
</html>
