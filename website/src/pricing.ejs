<%
// Data-driven page: the build orchestrator (scripts/build-i18n) exposes
// locals.i18nHelpers + locals.lang per locale; this resets ALL page-meta keys
// from the locale strings (killing the shared-locals bleed) and binds `t` to
// this page's strings. It runs BEFORE any output so <html lang> sees pageLang.
// EN renders byte-identical (modulo whitespace) to the legacy inline page.
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('pricing', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero H1 -->
<section class="relative pt-32 pb-8">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-display font-bold text-white"><%= t.hero.h1 %></h1>
        <p class="mt-4 text-xl text-gray-300 max-w-2xl mx-auto"><%= t.hero.tagline %></p>
    </div>
</section>

<% locals.hidePricingHeader = true; %>
<%- include('./includes/_pricing.ejs') %>

<!-- Why Hook0 Pricing is Different -->
<section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-surface-primary via-surface-secondary to-surface-primary"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <h2 class="text-heading-xl font-bold text-white"><%= t.differentiators.h2 %></h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
            <div class="animate-on-scroll text-center">
                <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-green-500/10 flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2"><%= t.differentiators.cards[0].title %></h3>
                <p class="text-gray-400 text-sm"><%= t.differentiators.cards[0].body %></p>
            </div>
            <div class="animate-on-scroll text-center">
                <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-indigo-500/10 flex items-center justify-center">
                    <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2"><%= t.differentiators.cards[1].title %></h3>
                <p class="text-gray-400 text-sm"><%= t.differentiators.cards[1].body %></p>
            </div>
            <div class="animate-on-scroll text-center">
                <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-orange-500/10 flex items-center justify-center">
                    <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2"><%= t.differentiators.cards[2].title %></h3>
                <p class="text-gray-400 text-sm"><%= t.differentiators.cards[2].body %></p>
            </div>
        </div>
    </div>
</section>

<!-- Pricing FAQ -->
<section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-surface-primary via-surface-secondary to-surface-primary"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <h2 class="text-heading-xl font-bold text-white"><%= t.faq.h2 %></h2>
        </div>
        <div class="space-y-4 stagger-children">
            <% t.faq.items.forEach(function (item) { %>
            <details class="faq-item animate-on-scroll group">
                <summary class="text-white font-medium">
                    <span><%= item.q %></span>
                    <svg class="w-5 h-5 text-gray-400 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </summary>
                <div class="faq-item__content">
                    <%- item.a %>
                </div>
            </details>
            <% }); %>
        </div>
    </div>
</section>

<%- include('./includes/_cta-inline.ejs') %>
<%- include('./includes/_footer.ejs') %>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver(function(entries) {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.animate-on-scroll').forEach(el => {
        observer.observe(el);
    });
});
</script>

</body>
</html>
