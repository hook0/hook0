<%
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('gdpr-subprocessors', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
    <style>
        .subprocessor-table {
            width: 100%;
            border-collapse: collapse;
            margin: 1.5rem 0;
        }
        .subprocessor-table th,
        .subprocessor-table td {
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem;
            text-align: left;
        }
        .subprocessor-table th {
            background-color: rgba(99, 102, 241, 0.3);
            color: white;
            font-weight: 600;
        }
        .subprocessor-table td {
            background-color: rgba(255, 255, 255, 0.02);
            color: #d1d5db;
        }
        .subprocessor-table tr:hover td {
            background-color: rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-24">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.title %>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>
        <div class="mt-4 inline-flex items-center px-4 py-2 rounded-full bg-white/10 text-sm text-gray-300">
            <svg class="w-4 h-4 mr-2 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <%= t.hero.lastUpdatedLabel %> <%= t.hero.lastUpdatedDate %>
        </div>
    </div>
</section>

<!-- Main Content Section -->
<section class="relative bg-surface-primary py-16 sm:py-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 top-1/4 right-0 opacity-10"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 bottom-1/4 left-0 opacity-10"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Introduction -->
        <div class="card card--glow mb-8 animate-on-scroll">
            <div class="prose prose-invert prose-lg max-w-none">
                <p class="text-gray-300 leading-relaxed"><%- t.intro.p1Html %></p>
                <p class="text-gray-300 leading-relaxed"><%- t.intro.p2Html %></p>
            </div>
        </div>

        <!-- What is Personal Data -->
        <div class="mb-8 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= t.whatIsPersonalData.title %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <div class="card card--glow">
                <p class="text-gray-300 leading-relaxed"><%- t.whatIsPersonalData.bodyHtml %></p>
            </div>
        </div>

        <!-- How We Process Personal Data -->
        <div class="mb-8 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= t.howWeProcess.title %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <div class="card card--glow">
                <p class="text-gray-300 leading-relaxed"><%- t.howWeProcess.bodyHtml %></p>
            </div>
        </div>

        <!-- Subprocessors and Their Roles -->
        <div class="mb-8 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= t.roles.title %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <div class="card card--glow">
                <p class="text-gray-300 leading-relaxed"><%- t.roles.p1Html %></p>
                <p class="text-gray-300 leading-relaxed mt-4"><%- t.roles.p2Html %></p>
            </div>
        </div>

        <!-- Infrastructure -->
        <div class="mb-8 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= t.infrastructure.title %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <div class="card card--glow">
                <p class="text-gray-300 leading-relaxed mb-6">
                    <%= t.infrastructure.intro %>
                </p>
                <div class="overflow-x-auto">
                    <table class="subprocessor-table">
                        <thead>
                            <tr>
                                <% t.infrastructure.table.headers.forEach(function (h) { %>
                                <th><%= h %></th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% t.infrastructure.table.rows.forEach(function (r) { %>
                            <tr>
                                <td><%= r.name %></td>
                                <td>
                                    <% if (r.countryIsEU) { %>
                                    <span class="inline-flex items-center">
                                        <img src="svg/europe-flag.svg" alt="EU" class="w-4 h-4 mr-2" loading="lazy">
                                        <%= r.country %>
                                    </span>
                                    <% } else { %>
                                    <%= r.country %>
                                    <% } %>
                                </td>
                                <td><%= r.purpose %></td>
                                <td><%= r.transfer %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Processing of Customer Content -->
        <div class="mb-8 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= t.customerContent.title %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <div class="card card--glow">
                <p class="text-gray-300 leading-relaxed mb-6">
                    <%= t.customerContent.intro %>
                </p>
                <div class="overflow-x-auto">
                    <table class="subprocessor-table">
                        <thead>
                            <tr>
                                <% t.customerContent.table.headers.forEach(function (h) { %>
                                <th><%= h %></th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% t.customerContent.table.rows.forEach(function (r) { %>
                            <tr>
                                <td><%= r.name %></td>
                                <td>
                                    <% if (r.countryIsEU) { %>
                                    <span class="inline-flex items-center">
                                        <img src="svg/europe-flag.svg" alt="EU" class="w-4 h-4 mr-2" loading="lazy">
                                        <%= r.country %>
                                    </span>
                                    <% } else { %>
                                    <%= r.country %>
                                    <% } %>
                                </td>
                                <td><%= r.purpose %></td>
                                <td><%= r.transfer %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <p class="text-gray-500 text-sm mt-4">
                    <%- t.customerContent.footnoteHtml %>
                </p>
            </div>
        </div>

        <!-- Stay in Control -->
        <div class="mb-8 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= t.control.title %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <div class="card card--glow">
                <p class="text-gray-300 leading-relaxed"><%- t.control.bodyHtml %></p>
            </div>
        </div>

        <!-- Data Ownership and Management -->
        <div class="mb-8 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= t.dataOwnership.title %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <div class="card card--glow">
                <p class="text-gray-300 leading-relaxed mb-4"><%- t.dataOwnership.p1Html %></p>
                <p class="text-gray-300 leading-relaxed"><%- t.dataOwnership.p2Html %></p>
            </div>
        </div>

    </div>
</section>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
