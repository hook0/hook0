<%
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('mentions-legales', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-24">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.h1 %>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>
    </div>
</section>

<!-- Main Content Section -->
<section class="relative bg-surface-primary py-16 sm:py-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 top-1/4 right-0 opacity-10"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 bottom-1/4 left-0 opacity-10"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="card card--glow animate-on-scroll">
            <div class="prose prose-invert prose-lg max-w-none">

                <!-- Publisher Information -->
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-white mb-4"><%= t.publisher.h2 %></h2>
                    <p class="text-gray-300 leading-relaxed">
                        <%= t.publisher.intro %>
                    </p>
                    <ul class="text-gray-300 space-y-1 mt-4">
                        <% t.publisher.rows.forEach(function (row) { %>
                            <li><strong class="text-white"><%= row.label %>:</strong> <%= row.value %></li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Publication Director -->
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-white mb-4"><%= t.director.h2 %></h2>
                    <p class="text-gray-300 leading-relaxed">
                        <%- t.director.bodyHtml %>
                    </p>
                </div>

                <!-- Hosting Provider -->
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-white mb-4"><%= t.hosting.h2 %></h2>
                    <p class="text-gray-300 leading-relaxed">
                        <%= t.hosting.intro %>
                    </p>
                    <ul class="text-gray-300 space-y-1 mt-4">
                        <% t.hosting.rows.forEach(function (row) { %>
                            <li><strong class="text-white"><%= row.label %>:</strong> <%= row.value %></li>
                        <% }) %>
                    </ul>
                </div>

                <!-- CDN Provider -->
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-white mb-4"><%= t.cdn.h2 %></h2>
                    <p class="text-gray-300 leading-relaxed">
                        <%= t.cdn.intro %>
                    </p>
                    <ul class="text-gray-300 space-y-1 mt-4">
                        <% t.cdn.rows.forEach(function (row) { %>
                            <li><strong class="text-white"><%= row.label %>:</strong> <%= row.value %></li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Contact -->
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-white mb-4"><%= t.contact.h2 %></h2>
                    <p class="text-gray-300 leading-relaxed">
                        <%= t.contact.intro %>
                    </p>
                    <ul class="text-gray-300 space-y-1 mt-4">
                        <% t.contact.rows.forEach(function (row) { %>
                            <li><strong class="text-white"><%= row.label %>:</strong> <a href="mailto:<%= row.email %>" class="text-green-400 hover:text-green-300 transition-colors"><%= row.emailLabel %></a></li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Intellectual Property -->
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-white mb-4"><%= t.ip.h2 %></h2>
                    <p class="text-gray-300 leading-relaxed">
                        <%= t.ip.p1 %>
                    </p>
                    <p class="text-gray-300 leading-relaxed mt-4">
                        <%= t.ip.p2 %>
                    </p>
                    <p class="text-gray-300 leading-relaxed mt-4">
                        <%= t.ip.p3 %>
                    </p>
                </div>

                <!-- Personal Data -->
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-white mb-4"><%= t.personalData.h2 %></h2>
                    <p class="text-gray-300 leading-relaxed">
                        <%= t.personalData.p1 %>
                    </p>
                    <p class="text-gray-300 leading-relaxed mt-4">
                        <%- t.personalData.p2Html %>
                    </p>
                </div>

                <!-- Applicable Law -->
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-white mb-4"><%= t.law.h2 %></h2>
                    <p class="text-gray-300 leading-relaxed">
                        <%= t.law.p1 %>
                    </p>
                    <p class="text-gray-300 leading-relaxed mt-4">
                        <%= t.law.p2 %>
                    </p>
                </div>

            </div>
        </div>

    </div>
</section>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
