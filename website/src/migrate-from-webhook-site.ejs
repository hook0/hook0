<%
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('migrate-from-webhook-site', locals.lang || 'en')); }
var t = locals.t;
var getPath = (locals.i18nHelpers && locals.i18nHelpers.getPath) ? locals.i18nHelpers.getPath : function (s) { return './' + s; };
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>
<%- include('./includes/_breadcrumb.ejs') %>


<!-- Hero -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.titleBefore %>
            <span class="block text-gradient-green"><%= t.hero.titleAccent %></span>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group" onclick="trackEvent('CTA', 'Click', 'migrate-webhook-site-hero-register')">
                <%= t.hero.ctaPrimary %>
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </a>
            <a href="https://play.hook0.com" target="_blank" rel="noopener" class="btn btn--secondary btn--lg" onclick="trackEvent('CTA', 'Click', 'migrate-webhook-site-hero-playground')">
                <%= t.hero.ctaSecondary %>
            </a>
        </div>
        <p class="mt-4 text-sm text-gray-500"><%= t.hero.ctaNote %></p>
    </div>
</section>

<%- include('./includes/_social-proof-bar.ejs') %>

<!-- Same problem, different tools -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.vsTable.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.vsTable.h2 %></h2>
            <p class="mt-4 text-body text-gray-400 max-w-2xl mx-auto"><%= t.vsTable.sub %></p>
        </div>

        <div class="animate-on-scroll overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.vsTable.headers.need %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.vsTable.headers.webhookSite %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-green-400 uppercase tracking-wider"><%= t.vsTable.headers.hook0 %></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% t.vsTable.rows.forEach(function (r) { %>
                    <tr>
                        <td class="py-4 px-6 text-gray-300"><%= r.need %></td>
                        <td class="py-4 px-6 <%= r.webhookSitePositive ? 'text-green-400 font-medium' : 'text-gray-400' %>"><%= r.webhookSite %></td>
                        <td class="py-4 px-6 <%= r.hook0Positive ? 'text-green-400 font-medium' : 'text-gray-400' %>"><%= r.hook0 %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Migration path -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.migration.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.migration.h2 %></h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8 stagger-children">
            <% t.migration.steps.forEach(function (s) { %>
            <div class="animate-on-scroll card card--glow p-6">
                <div class="text-green-400 font-bold mb-2"><%= s.index %></div>
                <h3 class="text-lg font-bold text-white mb-2"><%= s.title %></h3>
                <p class="text-gray-400"><%= s.body %></p>
            </div>
            <% }); %>
        </div>

        <div class="mt-12 animate-on-scroll card card--glow p-6 overflow-x-auto">
<pre class="text-sm text-gray-300"><code><%- t.migration.codeBlock %></code></pre>
        </div>

        <div class="mt-8 text-center">
            <a href="https://documentation.hook0.com/docs/getting-started" class="text-indigo-400 hover:text-indigo-300 underline" onclick="trackEvent('CTA', 'Click', 'migrate-webhook-site-docs')"><%= t.migration.docsLink %></a>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.faq.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.faq.h2 %></h2>
        </div>

        <div class="space-y-6 stagger-children">
            <% t.faq.items.forEach(function (item) { %>
            <div class="animate-on-scroll card card--glow p-6">
                <h3 class="text-lg font-semibold text-white mb-2"><%= item.q %></h3>
                <p class="text-gray-400"><%= item.a %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Related Pages -->
<section class="py-12 relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-lg font-semibold text-gray-400 mb-6 text-center"><%= t.related.h2 %></h2>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
            <% t.related.links.forEach(function (link) { %>
            <a href="<%= getPath(link.enSlug, locals.pageLang) %>" class="text-indigo-400 hover:text-indigo-300 underline"><%= link.label %></a>
            <% }); %>
        </div>
    </div>
</section>

<!-- CTA Section -->
<%- include('./includes/_cta-inline.ejs') %>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
