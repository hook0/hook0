<%
// Data-driven page: the build orchestrator (scripts/build-i18n) exposes
// locals.i18nHelpers + locals.lang per locale; this resets ALL page-meta keys
// from the locale strings (killing the shared-locals bleed) and binds `t` to
// this page's strings. It runs BEFORE any output so <html lang> sees pageLang.
// EN renders byte-identical (modulo whitespace) to the legacy inline page.
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('webhook-platform', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.titleLine1 %>
            <span class="block text-gradient-green"><%= t.hero.titleLine2 %></span>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group" onclick="trackEvent('CTA', 'Click', '<%= t.track %>-hero-register')">
                <%= t.hero.ctaPrimary %>
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </a>
            <a href="https://play.hook0.com" target="_blank" rel="noopener" class="btn btn--secondary btn--lg" onclick="trackEvent('CTA', 'Click', '<%= t.track %>-hero-playground')">
                <%= t.hero.ctaSecondary %>
            </a>
        </div>
        <p class="mt-4 text-sm text-gray-500"><%= t.hero.microcopy %></p>
    </div>
</section>

<% if (t.socialProof) { %>
<%- include('./includes/_social-proof-bar.ejs') %>
<% } %>

<!-- Capabilities -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 top-1/4 right-0 opacity-10"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.capabilities.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.capabilities.h2 %></h2>
            <p class="mt-4 text-body text-gray-400 max-w-2xl mx-auto"><%= t.capabilities.subtitle %></p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 stagger-children">
            <% t.capabilities.cards.forEach(function (c) { %>
            <div class="animate-on-scroll card card--glow p-8">
                <h3 class="text-xl font-bold text-white mb-3"><%= c.title %></h3>
                <p class="text-gray-400"><%= c.body %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- How it works -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.howItWorks.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.howItWorks.h2 %></h2>
        </div>

        <div class="animate-on-scroll card card--glow p-6 overflow-x-auto">
<pre class="text-sm text-gray-300"><code><%- t.howItWorks.code %></code></pre>
        </div>

        <div class="mt-8 text-center">
            <a href="<%= t.howItWorks.docsHref %>" class="text-indigo-400 hover:text-indigo-300 underline" onclick="trackEvent('CTA', 'Click', '<%= t.howItWorks.docsTrack %>')"><%= t.howItWorks.docsLabel %></a>
        </div>
    </div>
</section>

<% if (t.dataResidency) { %>
<!-- Data residency & sovereignty -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 bottom-0 left-0 opacity-10"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10 animate-on-scroll">
            <span class="section__eyebrow"><%= t.dataResidency.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.dataResidency.h2 %></h2>
        </div>

        <div class="space-y-5 text-body text-gray-400 animate-on-scroll">
            <% t.dataResidency.paras.forEach(function (p) { %>
            <p<%= p.emphasis ? ' class="text-gray-300"' : '' %>><%- p.html %></p>
            <% }); %>
        </div>
    </div>
</section>
<% } %>

<% if (t.openSource) { %>
<!-- Open source / no lock-in -->
<section class="section relative overflow-hidden">
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10 animate-on-scroll">
            <span class="section__eyebrow"><%= t.openSource.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.openSource.h2 %></h2>
        </div>
        <div class="space-y-5 text-body text-gray-400 text-center animate-on-scroll">
            <p><%- t.openSource.html.replace('{{GITHUB}}', locals.social.github.repoHref) %></p>
        </div>
    </div>
</section>
<% } %>

<!-- Build vs Buy -->
<section class="section relative overflow-hidden">
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.buildVsBuy.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.buildVsBuy.h2 %></h2>
        </div>

        <div class="animate-on-scroll overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.buildVsBuy.head[0] %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.buildVsBuy.head[1] %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-green-400 uppercase tracking-wider"><%= t.buildVsBuy.head[2] %></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% t.buildVsBuy.rows.forEach(function (r) { %>
                    <tr><td class="py-4 px-6 text-gray-300"><%= r[0] %></td><td class="py-4 px-6 text-gray-400"><%= r[1] %></td><td class="py-4 px-6 text-green-400 font-medium"><%= r[2] %></td></tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <% if (t.buildVsBuy.footHtml) { %>
        <div class="mt-8 text-center text-gray-400">
            <p><%- t.buildVsBuy.footHtml %></p>
        </div>
        <% } else { %>
        <div class="mt-8 text-center">
            <a href="<%= t.buildVsBuy.footHref %>" class="text-indigo-400 hover:text-indigo-300 underline"><%= t.buildVsBuy.footLabel %></a>
        </div>
        <% } %>
    </div>
</section>

<!-- FAQ Section -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.faq.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.faq.h2 %></h2>
        </div>

        <div class="space-y-6 stagger-children">
            <% t.faq.items.forEach(function (f) { %>
            <div class="animate-on-scroll card card--glow p-6">
                <h3 class="text-lg font-semibold text-white mb-2"><%= f.q %></h3>
                <p class="text-gray-400"><%= f.a %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Related Pages -->
<section class="py-12 relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-lg font-semibold text-gray-400 mb-6 text-center"><%= t.related.h2 %></h2>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
            <% t.related.links.forEach(function (l) { %>
            <a href="<%= l.href %>" class="text-indigo-400 hover:text-indigo-300 underline"><%= l.label %></a>
            <% }); %>
        </div>
    </div>
</section>

<% if (t.cta) { %>
<!-- CTA Section -->
<section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-indigo-900/20 via-surface-primary to-green-900/20"></div>
    <div class="blur-circle blur-circle--indigo w-80 h-80 -top-40 -left-40 opacity-30"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 -bottom-40 -right-40 opacity-30"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="animate-on-scroll">
            <h2 class="text-display font-bold text-white"><%= t.cta.h2 %></h2>
            <p class="mt-4 text-body-lg text-gray-400 max-w-2xl mx-auto">
                <%= t.cta.subtitle %>
            </p>

            <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
                <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group" onclick="trackEvent('CTA', 'Click', '<%= t.cta.track %>')">
                    <%= t.cta.ctaPrimary %>
                    <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                    </svg>
                </a>
                <a href="<%= t.cta.ctaSecondaryHref %>" class="btn btn--secondary btn--lg">
                    <%= t.cta.ctaSecondary %>
                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                    </svg>
                </a>
            </div>

            <div class="mt-8 flex flex-wrap gap-6 justify-center text-sm text-gray-500">
                <% t.cta.badges.forEach(function (b) { %>
                <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span><%= b %></span>
                </div>
                <% }); %>
            </div>
        </div>
    </div>
</section>
<% } else { %>
<%- include('./includes/_cta-inline.ejs') %>
<% } %>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
