<%
// Data-driven page: see scripts/build-i18n + locales/index.js for the engine.
// Object.assign at the very top resets every page-meta key from locale strings,
// killing the shared-locals bleed, and binds `t` to this page's strings.
// Runs BEFORE any output so <html lang> sees pageLang.
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('security', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-24">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.h1 %>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>
    </div>
</section>

<!-- Main Content Section -->
<section class="relative bg-surface-primary py-16 sm:py-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 top-1/4 right-0 opacity-10"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 bottom-1/4 left-0 opacity-10"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <% t.sections.forEach(function (section) { %>
        <div class="mb-12 animate-on-scroll">
            <div class="mb-6">
                <h2 class="text-display font-bold text-white"><%= section.h2 %></h2>
                <div class="mt-3 h-1 w-20 bg-gradient-to-r from-green-500 to-indigo-500 rounded-full"></div>
            </div>
            <% section.cards.forEach(function (card, idx) { %>
            <div class="card card--glow<% if (idx < section.cards.length - 1) { %> mb-6<% } %>">
                <% if (card.h3) { %>
                <h3 class="text-xl font-semibold text-white mb-4"><%= card.h3 %></h3>
                <% } %>
                <div class="prose prose-invert prose-lg max-w-none">
                    <% if (card.bodyHtml) { %>
                    <p class="text-gray-300 leading-relaxed">
                        <%- card.bodyHtml %>
                    </p>
                    <% } %>
                    <% if (card.bullets) { %>
                    <ul class="text-gray-300 space-y-2 mt-4">
                        <% card.bullets.forEach(function (b) { %>
                        <li class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                            <%= b %>
                        </li>
                        <% }); %>
                    </ul>
                    <% } %>
                    <% if (card.footHtml) { %>
                    <p class="text-gray-300 leading-relaxed mt-4">
                        <%- card.footHtml %>
                    </p>
                    <% } %>
                    <% if (card.paragraphs) { %>
                    <% card.paragraphs.forEach(function (p) { %>
                    <p class="text-gray-300 leading-relaxed">
                        <%- p %>
                    </p>
                    <% }); %>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>
        <% }); %>

    </div>
</section>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
