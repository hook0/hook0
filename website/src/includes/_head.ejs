<!-- Google Ads click identifier (gclid) bridging www <-> app via parent-domain cookie -->
<script>
(function(){
    var CONSENT_KEY='hook0_cookie_consent';
    var COOKIE_NAME='hook0_gclid';
    var COOKIE_TTL_SECONDS=30*24*60*60; // 30 days, matches signup_attribution TTL
    function getConsent(){try{return localStorage.getItem(CONSENT_KEY)}catch(e){return null}}
    function getUrlGclid(){try{return new URL(window.location.href).searchParams.get('gclid')}catch(e){return null}}
    function setGclidCookie(value){
        if(!value)return;
        var safe=String(value).replace(/[^A-Za-z0-9_-]/g,'').slice(0,256);
        if(!safe)return;
        document.cookie=COOKIE_NAME+'='+encodeURIComponent(safe)+
            '; Domain=.hook0.com; Path=/; Max-Age='+COOKIE_TTL_SECONDS+
            '; SameSite=Lax; Secure';
    }
    function clearGclidCookie(){
        document.cookie=COOKIE_NAME+'=; Domain=.hook0.com; Path=/; Max-Age=0; SameSite=Lax; Secure';
    }
    // If consent is already granted and a gclid is in the URL, persist it.
    if(getConsent()==='granted'){
        var g=getUrlGclid();
        if(g)setGclidCookie(g);
    }
    // Hook into the consent lifecycle.
    var origAccept=window.hook0Consent&&window.hook0Consent.accept;
    var origDeny=window.hook0Consent&&window.hook0Consent.deny;
    var origReset=window.hook0Consent&&window.hook0Consent.reset;
    if(window.hook0Consent){
        window.hook0Consent.accept=function(){
            if(origAccept)origAccept();
            var g=getUrlGclid();
            if(g)setGclidCookie(g);
        };
        window.hook0Consent.deny=function(){
            if(origDeny)origDeny();
            clearGclidCookie();
        };
        window.hook0Consent.reset=function(){
            if(origReset)origReset();
            clearGclidCookie();
        };
    }
})();
</script>
<% } %>

<% if (process.env.GOOGLE_ADS_CONVERSION_ID) { %>
<!-- Google Ads Conversion Tracking (loaded only with consent) -->
<script>
(function(){
    var CONSENT_KEY='hook0_cookie_consent';
    var GADS_ID='<%= process.env.GOOGLE_ADS_CONVERSION_ID %>';
    var GADS_SIGNUP_LABEL='<%= process.env.GOOGLE_ADS_CONVERSION_LABEL || "" %>';
    var gtagLoaded=false;

    function getConsent(){try{return localStorage.getItem(CONSENT_KEY)}catch(e){return null}}

    // Minimal gtag() function — queues commands before the script loads
    window.dataLayer=window.dataLayer||[];
    function gtag(){window.dataLayer.push(arguments);}
    window.gtag=gtag;

    function loadGtag(){
        if(gtagLoaded)return;
        gtagLoaded=true;
        gtag('js',new Date());
        gtag('config',GADS_ID,{send_page_view:false});
        var s=document.createElement('script');
        s.async=true;
        s.src='https://www.googletagmanager.com/gtag/js?id='+GADS_ID;
        document.head.appendChild(s);
    }

    // Load gtag only if consent was already granted
    if(getConsent()==='granted') loadGtag();

    // Patch consent handlers to also load gtag on accept
    var origAccept=window.hook0Consent&&window.hook0Consent.accept;
    var origDeny=window.hook0Consent&&window.hook0Consent.deny;
    if(window.hook0Consent){
        window.hook0Consent.accept=function(){if(origAccept)origAccept();loadGtag();};
        window.hook0Consent.deny=function(){if(origDeny)origDeny();};
    }

    // Track secondary conversions
    document.addEventListener('DOMContentLoaded',function(){
        // Conversion: Try Playground click
        document.querySelectorAll('a[href*="play.hook0.com"]').forEach(function(el){
            el.addEventListener('click',function(){
                if(gtagLoaded)gtag('event','conversion',{send_to:GADS_ID+'/playground_click'});
            });
        });
        // Conversion: Documentation visit
        document.querySelectorAll('a[href*="documentation.hook0.com"]').forEach(function(el){
            el.addEventListener('click',function(){
                if(gtagLoaded)gtag('event','conversion',{send_to:GADS_ID+'/documentation_visit'});
            });
        });
    });
})();
</script>
<% } %>

