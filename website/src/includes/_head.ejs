<!-- PWA: Service Worker & Manifest (added via JS to avoid Parcel resolution) -->
<script>
(function() {
  // Add manifest link dynamically
  var manifestLink = document.createElement('link');
  manifestLink.rel = 'manifest';
  manifestLink.href = ['', 'manifest.json'].join('/');
  document.head.appendChild(manifestLink);

  // Register Service Worker (using array join to avoid Parcel static analysis)
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function() {
      var swPath = ['', 'sw.js'].join('/');
      navigator.serviceWorker.register(swPath)
        .then(function(registration) {
          console.log('SW registered: ', registration.scope);
        })
        .catch(function(error) {
          console.log('SW registration failed: ', error);
        });
    });
  }
})();
</script>

<!-- Scroll Animation Script -->
<script defer>
document.addEventListener('DOMContentLoaded', function() {
    // Intersection Observer for scroll-triggered animations
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    document.querySelectorAll('.animate-on-scroll').forEach(function(el) {
        observer.observe(el);
    });

    // Header scroll effect
    const header = document.getElementById('main-header');
    if (header) {
        var lastScroll = 0;
        window.addEventListener('scroll', function() {
            var currentScroll = window.pageYOffset;
            if (currentScroll > 50) {
                header.classList.add('header-scrolled');
            } else {
                header.classList.remove('header-scrolled');
            }
            lastScroll = currentScroll;
        }, { passive: true });
    }

    // Card glow effect (mouse tracking)
    document.querySelectorAll('.card--glow').forEach(function(card) {
        card.addEventListener('mousemove', function(e) {
            var rect = card.getBoundingClientRect();
            var x = e.clientX - rect.left;
            var y = e.clientY - rect.top;
            card.style.setProperty('--mouse-x', x + 'px');
            card.style.setProperty('--mouse-y', y + 'px');
        });
    });
});
</script>

<!-- UTM/MTM/Google Ads Click ID Persistence -->
<script>
(function() {
    var STORAGE_KEY = 'hook0_tracking_params';
    var PARAM_NAMES = ['mtm_source','mtm_medium','mtm_campaign','utm_source','utm_medium','utm_campaign','gclid','wbraid','gbraid'];
    var params = new URLSearchParams(window.location.search);
    var tracked = {};
    var hasAny = false;
    PARAM_NAMES.forEach(function(name) {
        var val = params.get(name);
        if (val) { tracked[name] = val; hasAny = true; }
    });
    if (hasAny) {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(tracked));
    }
    document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href*="app.hook0.com"], a[href*="documentation.hook0.com"]');
        if (!link) return;
        var stored = sessionStorage.getItem(STORAGE_KEY);
        if (!stored) return;
        var data = JSON.parse(stored);
        var url = new URL(link.href);
        Object.keys(data).forEach(function(key) {
            if (!url.searchParams.has(key)) url.searchParams.set(key, data[key]);
        });
        link.href = url.toString();
    }, true);
})();
</script>
