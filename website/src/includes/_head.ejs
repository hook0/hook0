<meta name="format-detection" content="telephone=no">

<!-- Noindex -->
<% if (locals.pageNoindex) { %><meta name="robots" content="noindex, follow"><% } %>

<!-- SEO Meta Tags. Skip the global default on noindex utility pages — those
templates emit their own page-specific <meta name="description"> in their
head body, and the default fallback would just create a duplicate tag. -->
<% if (locals.pageDescription) { %>
<meta name="description" content="<%= locals.pageDescription %>">
<% } else if (!locals.pageNoindex) { %>
<meta name="description" content="<%= locals.seo.defaultDescription %>">
<% } %>

<!-- Canonical URL -->
<% if (locals.pageCanonical) { %>
<link rel="canonical" href="<%= locals.seo.siteUrl %><%= locals.pageCanonical %>">
<% } %>

<!-- hreflang alternates (localized versions). Self-referential link is intentionally
     omitted: it would duplicate the canonical URL and Parcel rewrites the colliding
     canonical href into a bundle hash. Cross-language reciprocity + x-default are kept.
     Bleed defense: pageHreflang from the previously-rendered page can leak into a
     non-converted page (one mutable `locals` across a Parcel run). If pageCanonical
     doesn't appear in pageHreflang, the set must have bled — skip emission entirely.
     Also skip any single entry whose href equals own canonical (homepage x-default
     case, or future self-referent leak). -->
<% if (locals.pageHreflang && locals.pageCanonical) {
     var __curLang = locals.pageLang || 'en';
     var __own = locals.pageCanonical;
     var __belongs = locals.pageHreflang.some(function(alt){ return alt.href === __own; });
     if (__belongs) {
       locals.pageHreflang.forEach(function(alt){ if (alt.lang !== __curLang && alt.href !== __own) { %>
<link rel="alternate" hreflang="<%= alt.lang %>" href="<%= locals.seo.siteUrl %><%= alt.href %>">
<%     } });
       if (__own !== '/') { %>
<link rel="alternate" hreflang="x-default" href="<%= locals.seo.siteUrl %>/">
<%     }
     }
} %>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="<%= locals.pageType || 'website' %>">
<meta property="og:site_name" content="<%= locals.seo.siteName %>">
<% if (locals.pageCanonical) { %>
<meta property="og:url" content="<%= locals.seo.siteUrl %><%= locals.pageCanonical %>">
<% } %>
<% if (locals.pageTitle) { %>
<meta property="og:title" content="<%= locals.pageTitle %>">
<% } else if (!locals.pageNoindex) { %>
<meta property="og:title" content="<%= locals.seo.defaultTitle %>">
<% } %>
<% if (locals.pageDescription) { %>
<meta property="og:description" content="<%= locals.pageDescription %>">
<% } else if (!locals.pageNoindex) { %>
<meta property="og:description" content="<%= locals.seo.defaultDescription %>">
<% } %>
<% if (locals.pageImage) { %>
<meta property="og:image" content="<%= locals.seo.siteUrl %><%= locals.pageImage %>">
<% } else if (!locals.pageNoindex) { %>
<meta property="og:image" content="<%= locals.seo.siteUrl %><%= locals.seo.defaultImage %>">
<% } %>
<% var __localeByLang = { en: 'en_US', fr: 'fr_FR', de: 'de_DE' }; var __pageLang = locals.pageLang || 'en'; %>
<meta property="og:locale" content="<%= __localeByLang[__pageLang] || locals.seo.locale %>">

