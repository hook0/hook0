<% var __cb = (locals.chrome && locals.chrome.cookieBanner) || { ariaLabel: 'Cookie consent', text: 'We use cookies on Hook0.com and its subdomains (including app.hook0.com) to analyze site usage, measure advertising performance, and improve your experience.', privacyLink: 'Privacy Policy', privacyHref: '/privacy-policy', decline: 'Decline', accept: 'Accept' }; %>
