<!-- Mobile Menu + Dropdown Script -->
<script>
(function() {
    var menuButton = document.getElementById('mobile-menu-button');
    var mobileMenu = document.getElementById('mobile-menu');
    var iconOpen = menuButton.querySelector('.mobile-menu-icon-open');
    var iconClose = menuButton.querySelector('.mobile-menu-icon-close');
    var backdrop = mobileMenu.querySelector('.mobile-menu__backdrop');

    function openMobileMenu() {
        mobileMenu.classList.add('is-open');
        menuButton.setAttribute('aria-expanded', 'true');
        mobileMenu.setAttribute('aria-hidden', 'false');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeMobileMenu() {
        mobileMenu.classList.remove('is-open');
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        document.body.style.overflow = '';
    }

    window.closeMobileMenu = closeMobileMenu;

    menuButton.addEventListener('click', function() {
        if (mobileMenu.classList.contains('is-open')) closeMobileMenu();
        else openMobileMenu();
    });

    backdrop.addEventListener('click', closeMobileMenu);

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && mobileMenu.classList.contains('is-open')) closeMobileMenu();
    });

    // ---- Desktop dropdown: click toggle + hover keep-open + Escape + outside-click ----
    var dropdowns = document.querySelectorAll('[data-nav-dropdown]');
    var openDropdown = null;

    function closeDropdown(dd) {
        var trigger = dd.querySelector('[aria-expanded]');
        dd.classList.remove('is-open');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
        if (openDropdown === dd) openDropdown = null;
    }
    function openOnly(dd) {
        dropdowns.forEach(function(other) { if (other !== dd) closeDropdown(other); });
        var trigger = dd.querySelector('[aria-expanded]');
        dd.classList.add('is-open');
        if (trigger) trigger.setAttribute('aria-expanded', 'true');
        openDropdown = dd;
    }

    dropdowns.forEach(function(dd) {
        var trigger = dd.querySelector('[data-nav-dropdown] > .nav-dropdown__trigger, .nav-dropdown__trigger');
        if (!trigger) return;

        trigger.addEventListener('click', function(e) {
            e.preventDefault();
            if (dd.classList.contains('is-open')) closeDropdown(dd);
            else openOnly(dd);
        });
        // Hover on the container also opens (mirrors the CSS but keeps aria-expanded truthful)
        dd.addEventListener('mouseenter', function() { openOnly(dd); });
        dd.addEventListener('mouseleave', function() { closeDropdown(dd); });
    });

    // Escape closes any open dropdown and returns focus to its trigger.
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && openDropdown) {
            var t = openDropdown.querySelector('.nav-dropdown__trigger');
            closeDropdown(openDropdown);
            if (t) t.focus();
        }
    });
    // Click outside any dropdown closes the open one.
    document.addEventListener('click', function(e) {
        if (!openDropdown) return;
        if (!openDropdown.contains(e.target)) closeDropdown(openDropdown);
    });

    // ---- Mobile accordion: single-open per group ----
    var mDrops = document.querySelectorAll('[data-mobile-dropdown-toggle]');
    mDrops.forEach(function(toggle) {
        var targetId = toggle.getAttribute('aria-controls');
        var target = document.getElementById(targetId);
        if (!target) return;
        toggle.addEventListener('click', function() {
            var isOpen = toggle.getAttribute('aria-expanded') === 'true';
            // Close every sibling first (single-open).
            mDrops.forEach(function(other) {
                if (other !== toggle) {
                    other.setAttribute('aria-expanded', 'false');
                    var otherTarget = document.getElementById(other.getAttribute('aria-controls'));
                    if (otherTarget) otherTarget.hidden = true;
                }
            });
            toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
            target.hidden = isOpen;
        });
    });
})();
</script>

