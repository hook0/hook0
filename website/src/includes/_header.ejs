<%
// Chrome strings: locale-aware when the calling page set locals.chrome via
// i18nHelpers.getPageLocals; otherwise fall back to EN hardcoded strings so
// non-converted legacy pages keep their EN render byte-identical.
var __cnav = (locals.chrome && locals.chrome.header && locals.chrome.header.nav) ? locals.chrome.header.nav : null;
var __ca11y = (locals.chrome && locals.chrome.header && locals.chrome.header.a11y) ? locals.chrome.header.a11y : null;
// Locale-aware path to /pricing when the page is converted AND the locale has
// a localized pricing slug; falls back to EN root for everyone else.
var __pricingHref = '/pricing';
if (locals.i18nHelpers && locals.pageLang) {
  var __p = locals.i18nHelpers.getPath('pricing', locals.pageLang);
  if (__p) __pricingHref = __p;
}
// Same for the homepage root anchors.
var __homeRoot = '/';
if (locals.i18nHelpers && locals.pageLang) {
  var __h = locals.i18nHelpers.getPath('index', locals.pageLang);
  if (__h) __homeRoot = __h;
}
// Locale flags for the language switcher. Decorative (aria-hidden) — the
// visible language name carries the accessible label.
var __FLAGS = {
  fr: '<svg class="flag" viewBox="0 0 3 2" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false"><rect width="3" height="2" fill="#fff"/><rect width="1" height="2" fill="#0055A4"/><rect x="2" width="1" height="2" fill="#EF4135"/></svg>',
  en: '<svg class="flag" viewBox="0 0 60 30" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false"><rect width="60" height="30" fill="#012169"/><path d="M0,0 60,30 M60,0 0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 60,30 M60,0 0,30" stroke="#C8102E" stroke-width="2.5"/><path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/><path d="M30,0 V30 M0,15 H60" stroke="#C8102E" stroke-width="6"/></svg>',
  de: '<svg class="flag" viewBox="0 0 5 3" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false"><rect width="5" height="1" fill="#000"/><rect y="1" width="5" height="1" fill="#DD0000"/><rect y="2" width="5" height="1" fill="#FFCE00"/></svg>',
};
var __flagFor = function (code) { return __FLAGS[code] || ''; };
var __langShort = function (code) { return code === 'fr' ? 'FR' : code === 'de' ? 'DE' : 'EN'; };
var __langFull = function (code) { return code === 'fr' ? 'Français' : code === 'de' ? 'Deutsch' : 'English'; };
%>
<!-- Accessibility: skip-to-main link. Visually hidden until focused, then
     becomes a fixed pill at the top-left. Targets <main id="main"> which the
     footer-paired wrapper at the end of this include opens. -->
<a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded-md focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-indigo-500"><%= __ca11y ? __ca11y.skipToMain : 'Skip to main content' %></a>

<!-- Header with glass morphism effect -->
<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <!-- Logo -->
            <a href="<%= __homeRoot %>" class="flex items-center gap-3 group">
                <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center
                            transition-transform duration-300 group-hover:scale-110 group-hover:shadow-glow-indigo">
                    <img src="<%= (typeof basePath !== 'undefined' && basePath) ? basePath : '.' %>/mediakit/logo/110x110-white.png" alt="Hook0" class="h-6 w-6 object-contain" />
                </div>
                <span class="text-white font-semibold text-lg hidden sm:block">Hook0</span>
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center gap-1">
                <a href="<%= __homeRoot %>#how-it-works" class="btn btn--ghost"><%= __cnav ? __cnav.howItWorks : 'How it works' %></a>
                <a href="<%= __homeRoot %>#use_cases" class="btn btn--ghost"><%= __cnav ? __cnav.useCases : 'Use cases' %></a>
                <a href="<%= __pricingHref %>" class="btn btn--ghost"><%= __cnav ? __cnav.pricing : 'Pricing' %></a>
                <a href="https://documentation.hook0.com/" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
                    <%= __cnav ? __cnav.documentation : 'Documentation' %>
                    <svg class="w-3.5 h-3.5 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                </a>
                <a href="https://play.hook0.com" target="_blank" rel="noopener" class="btn btn--ghost" onclick="trackEvent('Navigation', 'Click', 'Header Play')">
                    <%= __cnav ? __cnav.play : 'Play' %>
                    <svg class="w-3.5 h-3.5 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </a>
                <% if (!locals.pageNoindex && Array.isArray(locals.pageHreflang) && locals.pageHreflang.length > 1 && locals.pageCanonical && locals.pageHreflang.some(function(__a){ return __a.href === locals.pageCanonical; })) { %>
                <%# Lang switcher: pure HTML <details>/<summary> for graceful no-JS fallback,
                    pattern ported from lagrangessartaise.fr. Summary shows the active locale's
                    flag + short label + chevron; menu lists every alternate with flag + full name. %>
                <details class="lang-switcher ml-2 pl-2 border-l border-white/10">
                    <summary class="lang-switcher__summary inline-flex items-center gap-2 min-h-[44px] px-2.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hover:text-white hover:bg-white/5 rounded-md transition-colors cursor-pointer" aria-label="<%= __ca11y ? __ca11y.changeLanguage : 'Change language' %>">
                        <%- __flagFor(locals.pageLang || 'en') %>
                        <%= __langShort(locals.pageLang || 'en') %>
                        <svg class="lang-switcher__chevron w-2.5 h-2.5" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false">
                            <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="square" />
                        </svg>
                    </summary>
                    <ul class="lang-switcher__menu" role="menu">
                        <% locals.pageHreflang.forEach(function (alt) {
                            var __isActive = alt.lang === (locals.pageLang || 'en');
                        %>
                        <li role="none">
                            <a href="<%= alt.href %>"
                               hreflang="<%= alt.lang %>"
                               lang="<%= alt.lang %>"
                               role="menuitem"
                               <% if (__isActive) { %>aria-current="page"<% } %>
                               class="lang-switcher__item <%= __isActive ? 'lang-switcher__item--active' : '' %>">
                                <%- __flagFor(alt.lang) %>
                                <span class="lang-switcher__name"><%= __langFull(alt.lang) %></span>
                            </a>
                        </li>
                        <% }); %>
                    </ul>
                </details>
                <% } %>
            </div>

            <!-- Desktop Auth Buttons -->
            <div class="hidden md:flex items-center gap-3">
                <a href="<%= locals.meta.contact %>" class="btn btn--ghost">
                    <%= __cnav ? __cnav.contact : 'Contact' %>
                </a>
                <a href="<%= locals.meta.login %>" class="btn btn--ghost">
                    <%= __cnav ? __cnav.login : 'Login' %>
                </a>
                <a href="https://app.hook0.com/register" class="btn btn--primary btn--sm" onclick="trackEvent('CTA', 'Click', 'Start Free')">
                    <%= __cnav ? __cnav.startFree : 'Start Free' %>
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                    </svg>
                </a>
            </div>

            <!-- Mobile Menu Button -->
            <button
                id="mobile-menu-button"
                class="md:hidden p-3 min-w-[44px] min-h-[44px] flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/5 rounded-xl transition-colors touch-manipulation"
                aria-label="<%= __ca11y ? __ca11y.openMenu : 'Open menu' %>"
                aria-expanded="false"
                aria-controls="mobile-menu">
                <svg class="w-6 h-6 mobile-menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg class="w-6 h-6 mobile-menu-icon-close hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </nav>

    <!-- Mobile Navigation Panel -->
    <div
        id="mobile-menu"
        class="mobile-menu md:hidden"
        aria-hidden="true">
        <div class="mobile-menu__backdrop"></div>
        <div class="mobile-menu__panel">
            <!-- Mobile Nav Links -->
            <nav class="mobile-menu__nav">
                <a href="<%= __homeRoot %>#how-it-works" class="mobile-menu__link" onclick="closeMobileMenu()">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <%= __cnav ? __cnav.howItWorks : 'How it works' %>
                </a>
                <a href="<%= __homeRoot %>#use_cases" class="mobile-menu__link" onclick="closeMobileMenu()">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                    <%= __cnav ? __cnav.useCases : 'Use cases' %>
                </a>
                <a href="<%= __pricingHref %>" class="mobile-menu__link" onclick="closeMobileMenu()">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <%= __cnav ? __cnav.pricing : 'Pricing' %>
                </a>
                <a href="https://documentation.hook0.com/" target="_blank" rel="noopener noreferrer" class="mobile-menu__link">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                    </svg>
                    <%= __cnav ? __cnav.documentation : 'Documentation' %>
                    <svg class="w-4 h-4 ml-auto opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                </a>
                <a href="https://play.hook0.com" target="_blank" rel="noopener" class="mobile-menu__link" onclick="trackEvent('Navigation', 'Click', 'Mobile Play'); closeMobileMenu()">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <%= __cnav ? __cnav.play : 'Play' %>
                    <svg class="w-4 h-4 ml-auto opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                </a>
                <a href="<%= locals.meta.contact %>" class="mobile-menu__link" onclick="closeMobileMenu()">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    <%= __cnav ? __cnav.contact : 'Contact' %>
                </a>
            </nav>

            <% if (!locals.pageNoindex && Array.isArray(locals.pageHreflang) && locals.pageHreflang.length > 1 && locals.pageCanonical && locals.pageHreflang.some(function(__a){ return __a.href === locals.pageCanonical; })) { %>
            <div role="group" aria-label="<%= __ca11y ? __ca11y.changeLanguage : 'Change language' %>" class="mobile-menu__lang flex items-center gap-2 px-4 py-3 border-t border-white/10">
                <% locals.pageHreflang.forEach(function (alt) {
                    var __isActive = alt.lang === (locals.pageLang || 'en');
                %>
                <a href="<%= alt.href %>"
                   hreflang="<%= alt.lang %>"
                   lang="<%= alt.lang %>"
                   <% if (__isActive) { %>aria-current="page"<% } %>
                   class="lang-switcher__mobile-item <%= __isActive ? 'lang-switcher__mobile-item--active' : '' %>"
                   onclick="closeMobileMenu()">
                    <%- __flagFor(alt.lang) %>
                    <span><%= __langFull(alt.lang) %></span>
                </a>
                <% }); %>
            </div>
            <% } %>

            <!-- Mobile Auth Buttons -->
            <div class="mobile-menu__auth">
                <a href="<%= locals.meta.login %>" class="mobile-menu__auth-btn mobile-menu__auth-btn--secondary" onclick="closeMobileMenu()">
                    <%= __cnav ? __cnav.login : 'Login' %>
                </a>
                <a href="https://app.hook0.com/register" class="mobile-menu__auth-btn mobile-menu__auth-btn--primary" onclick="trackEvent('CTA', 'Click', 'Start Free'); closeMobileMenu()">
                    <%= __cnav ? __cnav.startFree : 'Start Free' %>
                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Menu Script -->
<script>
(function() {
    var menuButton = document.getElementById('mobile-menu-button');
    var mobileMenu = document.getElementById('mobile-menu');
    var iconOpen = menuButton.querySelector('.mobile-menu-icon-open');
    var iconClose = menuButton.querySelector('.mobile-menu-icon-close');
    var backdrop = mobileMenu.querySelector('.mobile-menu__backdrop');

    function openMobileMenu() {
        mobileMenu.classList.add('is-open');
        menuButton.setAttribute('aria-expanded', 'true');
        mobileMenu.setAttribute('aria-hidden', 'false');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeMobileMenu() {
        mobileMenu.classList.remove('is-open');
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        document.body.style.overflow = '';
    }

    window.closeMobileMenu = closeMobileMenu;

    menuButton.addEventListener('click', function() {
        var isOpen = mobileMenu.classList.contains('is-open');
        if (isOpen) {
            closeMobileMenu();
        } else {
            openMobileMenu();
        }
    });

    backdrop.addEventListener('click', closeMobileMenu);

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && mobileMenu.classList.contains('is-open')) {
            closeMobileMenu();
        }
    });
})();
</script>

<!-- Spacer for fixed header -->
<div class="h-20"></div>

<!-- Main landmark — paired with </main> opened at the top of _footer.ejs.
     tabindex="-1" so the skip-link click moves keyboard focus here. -->
<main id="main" tabindex="-1" class="outline-none">
