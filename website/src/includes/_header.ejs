<%
// Chrome strings: locale-aware when the calling page set locals.chrome via
// i18nHelpers.getPageLocals; otherwise fall back to EN hardcoded strings so
// non-converted legacy pages keep their EN render byte-identical.
var __cnav = (locals.chrome && locals.chrome.header && locals.chrome.header.nav) ? locals.chrome.header.nav : null;
var __ca11y = (locals.chrome && locals.chrome.header && locals.chrome.header.a11y) ? locals.chrome.header.a11y : null;
// Locale-aware path to /pricing when the page is converted AND the locale has
// a localized pricing slug; falls back to EN root for everyone else.
var __pricingHref = '/pricing';
if (locals.i18nHelpers && locals.pageLang) {
  var __p = locals.i18nHelpers.getPath('pricing', locals.pageLang);
  if (__p) __pricingHref = __p;
}
// Same for the homepage root anchors.
var __homeRoot = '/';
if (locals.i18nHelpers && locals.pageLang) {
  var __h = locals.i18nHelpers.getPath('index', locals.pageLang);
  if (__h) __homeRoot = __h;
}
// Dropdown groups. When present, render the new 5-slot dropdown nav; when
// absent (legacy pages that haven't set locals.chrome), fall back to the
// flat nav path further down. Setting `chrome.header.nav.groups = null` in
// any locale is a functional kill-switch back to the legacy layout.
var __groups = __cnav && __cnav.groups ? __cnav.groups : null;
var __lang = locals.pageLang || 'en';
// Resolve each dropdown item's href; skip items whose slug isn't translated.
var __resolveHref = function (enSlug) {
  if (!locals.i18nHelpers) return '/' + enSlug;
  var p = locals.i18nHelpers.getPath(enSlug, __lang);
  return p || null;
};
// Icon library — outline SVGs keyed by name string used in _chrome.js.
// currentColor + w-5 h-5 assumed at the call site (item template applies it).
var __ICONS = {
  bolt:    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M13 3L4 14h7v7l9-11h-7V3z"/>',
  api:     '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M8 3H5a2 2 0 00-2 2v3m6-5h3a2 2 0 012 2v3M8 21H5a2 2 0 01-2-2v-3m6 5h3a2 2 0 002-2v-3M9 12h6"/>',
  shield:  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M12 3l8 3v6c0 4.5-3.5 8.5-8 9-4.5-.5-8-4.5-8-9V6l8-3z"/>',
  anchor:  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M12 8v13m-6-4a6 6 0 0012 0M9 5a3 3 0 016 0 3 3 0 01-6 0zM4 17H2m20 0h-2"/>',
  compare: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M9 3v18M3 8h6M3 14h6m6-11l6 6m-6 12l6-6m-6-6h6"/>',
  swap:    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M7 3L3 7l4 4M3 7h13m-3 14l4-4-4-4m4 4H8"/>',
  scale:   '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M12 3v18M5 21h14M8 8L4 16h8L8 8zm8 0l-4 8h8l-4-8z"/>',
  code:    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M8 8l-5 4 5 4m8-8l5 4-5 4m-6 3l4-14"/>',
  server:  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M4 5h16v6H4V5zm0 8h16v6H4v-6zm3-5h.01M7 16h.01"/>',
  move:    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M9 20l-5-5 5-5m-5 5h13a4 4 0 004-4V4"/>',
  gift:    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M12 8v13M4 8h16v3H4V8zm2 3v10h12V11M9 8V6a2 2 0 114 0v2m-2 0h4a2 2 0 100-4"/>',
};
var __icon = function (name) {
  return '<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true" focusable="false">' + (__ICONS[name] || '') + '</svg>';
};
// Locale flags for the language switcher. Decorative (aria-hidden) — the
// visible language name carries the accessible label.
var __FLAGS = {
  fr: '<svg class="flag" viewBox="0 0 3 2" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false"><rect width="3" height="2" fill="#fff"/><rect width="1" height="2" fill="#0055A4"/><rect x="2" width="1" height="2" fill="#EF4135"/></svg>',
  en: '<svg class="flag" viewBox="0 0 60 30" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false"><rect width="60" height="30" fill="#012169"/><path d="M0,0 60,30 M60,0 0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 60,30 M60,0 0,30" stroke="#C8102E" stroke-width="2.5"/><path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/><path d="M30,0 V30 M0,15 H60" stroke="#C8102E" stroke-width="6"/></svg>',
  de: '<svg class="flag" viewBox="0 0 5 3" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false"><rect width="5" height="1" fill="#000"/><rect y="1" width="5" height="1" fill="#DD0000"/><rect y="2" width="5" height="1" fill="#FFCE00"/></svg>',
};
var __flagFor = function (code) { return __FLAGS[code] || ''; };
var __langShort = function (code) { return code === 'fr' ? 'FR' : code === 'de' ? 'DE' : 'EN'; };
var __langFull = function (code) { return code === 'fr' ? 'Français' : code === 'de' ? 'Deutsch' : 'English'; };
%>
<!-- Accessibility: skip-to-main link. Visually hidden until focused, then
     becomes a fixed pill at the top-left. Targets <main id="main"> which the
     footer-paired wrapper at the end of this include opens. -->
<a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded-md focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-indigo-500"><%= __ca11y ? __ca11y.skipToMain : 'Skip to main content' %></a>

<!-- Header with glass morphism effect -->
<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Primary">
        <div class="flex items-center justify-between h-20">
            <!-- Logo -->
            <a href="<%= __homeRoot %>" class="flex items-center gap-3 group">
                <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center
                            transition-transform duration-300 group-hover:scale-110 group-hover:shadow-glow-indigo">
                    <img src="<%= (typeof basePath !== 'undefined' && basePath) ? basePath : '.' %>/mediakit/logo/110x110-white.png" alt="Hook0" class="h-6 w-6 object-contain" />
                </div>
                <span class="text-white font-semibold text-lg hidden sm:block">Hook0</span>
            </a>

            <% if (__groups) { %>
            <!-- Desktop Nav — 5 slots: Platform ▾ · Compare ▾ · Solutions ▾ · Pricing · Docs↗ -->
            <div class="hidden md:flex items-center gap-1">
                <% ['platform','compare','solutions'].forEach(function(gkey) {
                     var g = __groups[gkey]; if (!g) return;
                     var itemsResolved = g.items.map(function(it){ var h = __resolveHref(it.enSlug); return h ? Object.assign({href:h}, it) : null; }).filter(Boolean);
                     if (!itemsResolved.length) return;
                     var isTwoCols = itemsResolved.length > 4;
                     var panelId = 'nav-dropdown-' + gkey; %>
                <div class="nav-dropdown" data-nav-dropdown>
                    <button type="button" class="nav-dropdown__trigger" aria-expanded="false" aria-haspopup="true" aria-controls="<%= panelId %>">
                        <span><%= g.label %></span>
                        <svg class="nav-dropdown__chevron" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false">
                            <path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <div class="nav-dropdown__panel" id="<%= panelId %>" role="region" aria-label="<%= g.label %>">
                        <!-- Invisible hover bridge so cursor can travel from trigger to panel -->
                        <div class="nav-dropdown__bridge" aria-hidden="true"></div>
                        <div class="nav-dropdown__panel-inner <%= isTwoCols ? 'nav-dropdown__panel-inner--two-cols' : '' %>">
                            <% itemsResolved.forEach(function(it) { %>
                            <a href="<%= it.href %>" class="nav-dropdown__item">
                                <span class="nav-dropdown__item-icon"><%- __icon(it.icon) %></span>
                                <span class="nav-dropdown__item-text">
                                    <span class="nav-dropdown__item-title"><%= it.label %></span>
                                    <% if (it.description) { %><span class="nav-dropdown__item-desc"><%= it.description %></span><% } %>
                                </span>
                            </a>
                            <% }); %>
                        </div>
                    </div>
                </div>
                <% }); %>
                <a href="<%= __pricingHref %>" class="nav-link"><%= __cnav.pricing %></a>
                <a href="https://documentation.hook0.com/" target="_blank" rel="noopener noreferrer" class="nav-link">
                    <%= __cnav.documentation %>
                    <svg class="w-3 h-3 ml-0.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
            </div>

            <!-- Desktop right zone: Play · GitHub · Login · Start Free · Lang -->
            <div class="hidden md:flex items-center gap-2">
                <a href="https://play.hook0.com" target="_blank" rel="noopener" class="nav-link nav-link--icon" title="Try Hook0 live" aria-label="Try Hook0 live at play.hook0.com" onclick="trackEvent('Navigation', 'Click', 'Header Play')">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <span class="hidden lg:inline"><%= __cnav.play %></span>
                </a>
                <a href="https://gitlab.com/hook0/hook0" target="_blank" rel="noopener" class="nav-link nav-link--icon" title="View source on GitLab" aria-label="View source on GitLab">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.6 9.6L23.6 9.5 20.2 0.7c-0.1-0.2-0.2-0.3-0.4-0.4-0.2-0.1-0.4-0.1-0.6-0.1s-0.4 0.1-0.5 0.3c-0.1 0.2-0.2 0.3-0.3 0.5L15.9 8H8.1L5.7 0.9c-0.1-0.2-0.2-0.4-0.3-0.5-0.1-0.1-0.3-0.2-0.5-0.3s-0.4 0-0.6 0.1c-0.2 0.1-0.3 0.2-0.4 0.4L0.5 9.5v0.1L0.4 9.7c-0.5 1.3-0.1 2.7 1 3.5l0.1 0 8.7 6.3 4.3 3.3 2.6 2c0.3 0.2 0.7 0.2 1 0l2.6-2 4.3-3.3 8.7-6.3 0 0c1.1-0.8 1.5-2.2 1-3.5z"/></svg>
                </a>
                <a href="<%= locals.meta.login %>" class="nav-link"><%= __cnav.login %></a>
                <a href="https://app.hook0.com/register" class="btn btn--primary btn--sm" onclick="trackEvent('CTA', 'Click', 'Start Free')">
                    <%= __cnav.startFree %>
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>
                <% if (!locals.pageNoindex && Array.isArray(locals.pageHreflang) && locals.pageHreflang.length > 1 && locals.pageCanonical && locals.pageHreflang.some(function(__a){ return __a.href === locals.pageCanonical; })) { %>
                <details class="lang-switcher ml-1 pl-2 border-l border-white/10">
                    <summary class="lang-switcher__summary inline-flex items-center gap-2 min-h-[44px] px-2.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hover:text-white hover:bg-white/5 rounded-md transition-colors cursor-pointer" aria-label="<%= __ca11y ? __ca11y.changeLanguage : 'Change language' %>">
                        <%- __flagFor(__lang) %>
                        <%= __langShort(__lang) %>
                        <svg class="lang-switcher__chevron w-2.5 h-2.5" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/></svg>
                    </summary>
                    <ul class="lang-switcher__menu" role="menu">
                        <% locals.pageHreflang.forEach(function (alt) { var __isActive = alt.lang === __lang; %>
                        <li role="none"><a href="<%= alt.href %>" hreflang="<%= alt.lang %>" lang="<%= alt.lang %>" role="menuitem"<% if (__isActive) { %> aria-current="page"<% } %> class="lang-switcher__item <%= __isActive ? 'lang-switcher__item--active' : '' %>"><%- __flagFor(alt.lang) %><span class="lang-switcher__name"><%= __langFull(alt.lang) %></span></a></li>
                        <% }); %>
                    </ul>
                </details>
                <% } %>
            </div>
            <% } else { %>
            <!-- Legacy flat nav (kept for pages that don't inject chrome.header.nav.groups). -->
            <div class="hidden md:flex items-center gap-1">
                <a href="<%= __homeRoot %>#how-it-works" class="btn btn--ghost"><%= __cnav ? __cnav.howItWorks : 'How it works' %></a>
                <a href="<%= __homeRoot %>#use_cases" class="btn btn--ghost"><%= __cnav ? __cnav.useCases : 'Use cases' %></a>
                <a href="<%= __pricingHref %>" class="btn btn--ghost"><%= __cnav ? __cnav.pricing : 'Pricing' %></a>
                <a href="https://documentation.hook0.com/" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
                    <%= __cnav ? __cnav.documentation : 'Documentation' %>
                    <svg class="w-3.5 h-3.5 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </a>
                <a href="https://play.hook0.com" target="_blank" rel="noopener" class="btn btn--ghost" onclick="trackEvent('Navigation', 'Click', 'Header Play')">
                    <%= __cnav ? __cnav.play : 'Play' %>
                    <svg class="w-3.5 h-3.5 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </a>
                <% if (!locals.pageNoindex && Array.isArray(locals.pageHreflang) && locals.pageHreflang.length > 1 && locals.pageCanonical && locals.pageHreflang.some(function(__a){ return __a.href === locals.pageCanonical; })) { %>
                <details class="lang-switcher ml-2 pl-2 border-l border-white/10">
                    <summary class="lang-switcher__summary inline-flex items-center gap-2 min-h-[44px] px-2.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hover:text-white hover:bg-white/5 rounded-md transition-colors cursor-pointer" aria-label="<%= __ca11y ? __ca11y.changeLanguage : 'Change language' %>">
                        <%- __flagFor(__lang) %>
                        <%= __langShort(__lang) %>
                        <svg class="lang-switcher__chevron w-2.5 h-2.5" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/></svg>
                    </summary>
                    <ul class="lang-switcher__menu" role="menu">
                        <% locals.pageHreflang.forEach(function (alt) { var __isActive = alt.lang === __lang; %>
                        <li role="none"><a href="<%= alt.href %>" hreflang="<%= alt.lang %>" lang="<%= alt.lang %>" role="menuitem"<% if (__isActive) { %> aria-current="page"<% } %> class="lang-switcher__item <%= __isActive ? 'lang-switcher__item--active' : '' %>"><%- __flagFor(alt.lang) %><span class="lang-switcher__name"><%= __langFull(alt.lang) %></span></a></li>
                        <% }); %>
                    </ul>
                </details>
                <% } %>
            </div>
            <div class="hidden md:flex items-center gap-3">
                <a href="<%= locals.meta.contact %>" class="btn btn--ghost"><%= __cnav ? __cnav.contact : 'Contact' %></a>
                <a href="<%= locals.meta.login %>" class="btn btn--ghost"><%= __cnav ? __cnav.login : 'Login' %></a>
                <a href="https://app.hook0.com/register" class="btn btn--primary btn--sm" onclick="trackEvent('CTA', 'Click', 'Start Free')"><%= __cnav ? __cnav.startFree : 'Start Free' %><svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg></a>
            </div>
            <% } %>

            <!-- Mobile Menu Button -->
            <button
                id="mobile-menu-button"
                class="md:hidden p-3 min-w-[44px] min-h-[44px] flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/5 rounded-xl transition-colors touch-manipulation"
                aria-label="<%= __ca11y ? __ca11y.openMenu : 'Open menu' %>"
                aria-expanded="false"
                aria-controls="mobile-menu">
                <svg class="w-6 h-6 mobile-menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                <svg class="w-6 h-6 mobile-menu-icon-close hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
    </nav>

    <!-- Mobile Navigation Panel -->
    <div id="mobile-menu" class="mobile-menu md:hidden" aria-hidden="true">
        <div class="mobile-menu__backdrop"></div>
        <div class="mobile-menu__panel">
            <% if (__groups) { %>
            <!-- Primary CTA at top of panel (Baymard: TOP converts +23% vs bottom) -->
            <div class="mobile-menu__cta">
                <a href="https://app.hook0.com/register" class="mobile-menu__auth-btn mobile-menu__auth-btn--primary" onclick="trackEvent('CTA', 'Click', 'Start Free'); closeMobileMenu()">
                    <%= __cnav.startFree %>
                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>
                <a href="<%= locals.meta.login %>" class="mobile-menu__login-link" onclick="closeMobileMenu()"><%= __cnav.login %></a>
            </div>
            <nav class="mobile-menu__nav" aria-label="Primary mobile">
                <% ['platform','compare','solutions'].forEach(function(gkey) {
                     var g = __groups[gkey]; if (!g) return;
                     var itemsResolved = g.items.map(function(it){ var h = __resolveHref(it.enSlug); return h ? Object.assign({href:h}, it) : null; }).filter(Boolean);
                     if (!itemsResolved.length) return;
                     var panelId = 'mnav-dropdown-' + gkey; %>
                <div class="mobile-menu__group">
                    <button type="button" class="mobile-menu__group-toggle" aria-expanded="false" aria-controls="<%= panelId %>" data-mobile-dropdown-toggle>
                        <span><%= g.label %></span>
                        <svg class="mobile-menu__group-chevron" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <div class="mobile-menu__group-body" id="<%= panelId %>" hidden data-mobile-dropdown>
                        <% itemsResolved.forEach(function(it) { %>
                        <a href="<%= it.href %>" class="mobile-menu__group-link" onclick="closeMobileMenu()">
                            <span class="mobile-menu__group-link-icon"><%- __icon(it.icon) %></span>
                            <span class="mobile-menu__group-link-text">
                                <span class="mobile-menu__group-link-title"><%= it.label %></span>
                                <% if (it.description) { %><span class="mobile-menu__group-link-desc"><%= it.description %></span><% } %>
                            </span>
                        </a>
                        <% }); %>
                    </div>
                </div>
                <% }); %>
                <a href="<%= __pricingHref %>" class="mobile-menu__link" onclick="closeMobileMenu()">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <%= __cnav.pricing %>
                </a>
                <a href="https://documentation.hook0.com/" target="_blank" rel="noopener noreferrer" class="mobile-menu__link">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    <%= __cnav.documentation %>
                    <svg class="w-4 h-4 ml-auto opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
                <a href="https://play.hook0.com" target="_blank" rel="noopener" class="mobile-menu__link" onclick="trackEvent('Navigation', 'Click', 'Mobile Play'); closeMobileMenu()">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <%= __cnav.play %>
                    <svg class="w-4 h-4 ml-auto opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
            </nav>
            <% } else { %>
            <!-- Legacy flat mobile nav -->
            <nav class="mobile-menu__nav">
                <a href="<%= __homeRoot %>#how-it-works" class="mobile-menu__link" onclick="closeMobileMenu()">
