<a name="customers" id="customers"></a>
<section class="relative bg-surface-secondary py-24 sm:py-32 overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 gradient-mesh opacity-50"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 items-center gap-x-16 gap-y-16 lg:grid-cols-2">
            <!-- Left Column - Text -->
            <div class="animate-on-scroll animate-on-scroll--left">
                <span class="section__eyebrow">Social Proof</span>
                <h2 class="text-display font-bold text-white">
                    Trusted by companies worldwide
                </h2>
                <p class="mt-6 text-body-lg text-gray-400 leading-relaxed">
                    These teams chose Hook0 over competitors because Hook0 publishes its full server source (SSPL-1.0) and also offers production-ready SaaS support. They gain a competitive advantage by embracing extensibility, reversibility, and future-proofness in their integration strategies.
                </p>
                <div class="mt-8">
                    <a href="/pricing" class="link link--arrow text-indigo-400 hover:text-indigo-300">
                        Join them today
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Right Column - Logo Grid (animated rotation, see src/js/logo-wall.js) -->
            <div class="animate-on-scroll animate-on-scroll--right">
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 lg:gap-10" data-logo-rotator>
                    <% locals.customers.slice(0, 6).forEach(c => { %>
                    <div class="logo-cell rounded-2xl bg-white/5 border border-white/5
                                hover:bg-white/10 hover:border-white/10 transition-all duration-300" data-logo-cell>
                        <img class="logo-layer logo-layer--active" src="<%= c.logo %>" alt="<%= c.name %>" data-logo="<%= c.logo %>" width="120" height="40" loading="lazy" />
                        <img class="logo-layer" alt="" />
                    </div>
                    <% }) %>
                </div>
                <%# Full logo pool (incl. benched logos), preloaded & resolved by the bundler so the
                    rotation script gets the final (hashed) asset URLs. `data-logo` is the stable
                    identity key. No hardcoded list in JS — the pool is discovered from the DOM. %>
                <div class="hidden" data-logo-pool aria-hidden="true">
                    <% locals.customers.forEach(c => { %>
                    <img src="<%= c.logo %>" data-logo="<%= c.logo %>" data-name="<%= c.name %>" data-pinned="<%= c.pinned %>" alt="" />
                    <% }) %>
                </div>
                <%# Logo rotation — Parcel-bundled module, not inline JS (see website/CLAUDE.md). %>
                <script type="module" src="./js/logo-wall.js"></script>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="mt-16 pt-16 border-t border-white/10">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 stagger-children">
                <div class="animate-on-scroll text-center">
                    <div class="text-4xl sm:text-5xl font-extrabold text-gradient-green">99.9%</div>
                    <div class="mt-2 text-sm font-medium text-gray-400">Uptime SLA</div>
                </div>
                <div class="animate-on-scroll text-center">
                    <div class="text-4xl sm:text-5xl font-extrabold text-gradient-indigo">10M+</div>
                    <div class="mt-2 text-sm font-medium text-gray-400">Webhooks Delivered</div>
                </div>
                <div class="animate-on-scroll text-center">
                    <div class="text-4xl sm:text-5xl font-extrabold text-gradient">&lt;100ms</div>
                    <div class="mt-2 text-sm font-medium text-gray-400">Avg. Delivery Time</div>
                </div>
                <div class="animate-on-scroll text-center">
                    <div class="text-4xl sm:text-5xl font-extrabold text-white">6</div>
                    <div class="mt-2 text-sm font-medium text-gray-400">Continents Served</div>
                </div>
            </div>
        </div>
    </div>
</section>
