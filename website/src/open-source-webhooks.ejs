<%
// Data-driven page: see scripts/build-i18n + locales/index.js for the engine.
// Object.assign at the very top resets every page-meta key from locale strings,
// killing the shared-locals bleed, and binds `t` to this page's strings.
// Runs BEFORE any output so <html lang> sees pageLang.
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('open-source-webhooks', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.titleLine1 %>
            <span class="block text-gradient-green"><%= t.hero.titleLine2 %></span>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group" onclick="trackEvent('CTA', 'Click', '<%= t.hero.ctaPrimaryTrack %>')">
                <%= t.hero.ctaPrimary %>
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </a>
            <a href="<%= t.hero.ctaSecondaryHref %>" target="_blank" rel="noopener" class="btn btn--secondary btn--lg" onclick="trackEvent('CTA', 'Click', '<%= t.hero.ctaSecondaryTrack %>')">
                <%= t.hero.ctaSecondary %>
            </a>
        </div>

        <!-- Trust Indicators -->
        <div class="mt-10 flex flex-wrap gap-6 justify-center text-sm text-gray-400 animate-on-scroll">
            <% t.hero.trustIndicators.forEach(function (ind) { %>
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span><%= ind %></span>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<% if (t.socialProof) { %>
<%- include('./includes/_social-proof-bar.ejs') %>
<% } %>

<!-- Why Open-Source Matters -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 top-1/4 right-0 opacity-10"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.whyOss.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.whyOss.h2 %></h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 stagger-children">
            <% t.whyOss.cards.forEach(function (c, i) { %>
            <% var iconBg = (i % 2 === 0) ? 'bg-green-500/10 border-green-500/20' : 'bg-indigo-500/10 border-indigo-500/20'; %>
            <% var iconColor = (i % 2 === 0) ? 'text-green-400' : 'text-indigo-400'; %>
            <div class="animate-on-scroll card card--glow p-8">
                <div class="w-12 h-12 rounded-xl <%= iconBg %> border flex items-center justify-center mb-6">
                    <% if (c.icon === 'audit') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                    </svg>
                    <% } else if (c.icon === 'lock') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                    </svg>
                    <% } else if (c.icon === 'selfhost') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"></path>
                    </svg>
                    <% } else if (c.icon === 'community') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <% } %>
                </div>
                <h3 class="text-xl font-bold text-white mb-3"><%= c.title %></h3>
                <p class="text-gray-400">
                    <%= c.body %>
                </p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Comparison Table -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.comparison.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.comparison.h2 %></h2>
        </div>

        <div class="animate-on-scroll overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.comparison.columns.criteria %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-green-400 uppercase tracking-wider"><%= t.comparison.columns.sspl %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.comparison.columns.openCore %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.comparison.columns.mit %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.comparison.columns.proprietary %></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% t.comparison.rows.forEach(function (r) { %>
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="py-4 px-6 text-gray-300"><%= r.criteria %></td>
                        <td class="py-4 px-6 text-green-400 font-medium"><%= r.sspl %></td>
                        <td class="py-4 px-6 text-gray-400"><%= r.openCore %></td>
                        <td class="py-4 px-6 text-gray-400"><%= r.mit %></td>
                        <td class="py-4 px-6 text-gray-400"><%= r.proprietary %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Key Differentiators -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 bottom-1/4 left-0 opacity-10"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.differentiators.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.differentiators.h2 %></h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6 stagger-children">
            <% t.differentiators.cards.forEach(function (c, i) { %>
            <% var iconBg = (i % 2 === 0) ? 'bg-green-500/10 border-green-500/20' : 'bg-indigo-500/10 border-indigo-500/20'; %>
            <% var iconColor = (i % 2 === 0) ? 'text-green-400' : 'text-indigo-400'; %>
            <div class="animate-on-scroll card card--glow p-6 text-center">
                <div class="w-12 h-12 rounded-xl <%= iconBg %> border flex items-center justify-center mx-auto mb-4">
                    <% if (c.icon === 'audit') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                    </svg>
                    <% } else if (c.icon === 'lock') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                    </svg>
                    <% } else if (c.icon === 'cloud') { %>
                    <svg class="w-6 h-6 <%= iconColor %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                    </svg>
                    <% } %>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2"><%= c.title %></h3>
                <p class="text-sm text-gray-400"><%= c.body %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.faq.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.faq.h2 %></h2>
        </div>

        <div class="space-y-6 stagger-children">
            <% t.faq.items.forEach(function (f) { %>
            <div class="animate-on-scroll card card--glow p-6">
                <h3 class="text-lg font-semibold text-white mb-2"><%= f.q %></h3>
                <p class="text-gray-400"><%- f.a %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Related Pages -->
<section class="py-12 relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-lg font-semibold text-gray-400 mb-6 text-center"><%= t.related.h2 %></h2>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
            <% t.related.links.forEach(function (l) { %>
            <a href="<%= l.href %>" class="text-indigo-400 hover:text-indigo-300 underline"><%= l.label %></a>
            <% }); %>
        </div>
    </div>
</section>

<!-- CTA Section -->
<%- include('./includes/_cta-inline.ejs') %>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
