<%
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('built-to-last', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center gradient-hero overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 left-1/4"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/3 right-1/4"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 bottom-20 left-1/2 opacity-30"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32 text-center">
        <!-- Badge -->
        <div class="animate-on-scroll inline-flex items-center gap-3 px-1 pr-4 py-1 rounded-full
                    bg-white/5 border border-white/10 backdrop-blur-sm mb-8">
            <span class="px-3 py-1 text-xs font-semibold tracking-wide bg-green-500 text-white rounded-full">
                <%= t.hero.badge %>
            </span>
            <span class="text-sm text-gray-300">
                <%= t.hero.badgeNote %>
            </span>
        </div>

        <!-- Headline -->
        <h1 class="animate-on-scroll text-display-xl text-white mb-6">
            <%= t.hero.titleBefore %>
            <span class="block text-gradient-green mt-2 pb-1 leading-relaxed"><%= t.hero.titleAccent %></span>
        </h1>

        <!-- Description -->
        <p class="animate-on-scroll text-body-lg text-gray-400 max-w-3xl mx-auto">
            <%= t.hero.subtitle %>
        </p>

        <!-- Trust Metrics -->
        <div class="animate-on-scroll mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto stagger-children">
            <% var __metricColors = ['indigo', 'green', 'indigo']; %>
            <% t.hero.metrics.forEach(function (m, i) { var c = __metricColors[i] || 'indigo'; %>
            <div class="glass rounded-2xl p-6">
                <div class="text-4xl font-extrabold text-gradient-<%= c %> mb-2 pb-1 leading-relaxed"><%= m.value %></div>
                <div class="text-sm text-gray-400"><%= m.label %></div>
            </div>
            <% }); %>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
        <div class="flex flex-col items-center gap-2">
            <span class="text-sm text-gray-400 uppercase tracking-wider"><%= t.hero.scroll %></span>
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
        </div>
    </div>
</section>

<!-- Mission Statement -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-30"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="animate-on-scroll text-center mb-16">
            <span class="section__eyebrow"><%= t.mission.eyebrow %></span>
            <h2 class="section__title"><%= t.mission.h2 %></h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 stagger-children">
            <% var __missionIcons = [
              { color: 'indigo', path: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
              { color: 'green', path: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
            ]; %>
            <% t.mission.cards.forEach(function (c, i) { var icon = __missionIcons[i] || __missionIcons[0]; %>
            <div class="animate-on-scroll card card--glow">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 rounded-xl bg-<%= icon.color %>-500/10 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-<%= icon.color %>-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon.path %>"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-semibold text-white mb-3"><%= c.title %></h3>
                        <p class="text-gray-400">
                            <%- c.body %>
                        </p>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Core Principles -->
<section class="section relative overflow-hidden bg-surface-secondary">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--green w-96 h-96 top-1/4 -left-48 opacity-20"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="animate-on-scroll text-center mb-16">
            <span class="section__eyebrow"><%= t.principles.eyebrow %></span>
            <h2 class="section__title"><%= t.principles.h2 %></h2>
        </div>

        <div class="space-y-8 stagger-children">
            <% var __principleIcons = [
              'M13 10V3L4 14h7v7l9-11h-7z',
              'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
              'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
              'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
            ]; %>
            <% t.principles.cards.forEach(function (c, i) { var iconPath = __principleIcons[i] || __principleIcons[0]; %>
            <div class="animate-on-scroll primary-feature">
                <div class="primary-feature-icon">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= iconPath %>"></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-white mb-4"><%= c.title %></h3>
                <p class="text-gray-400 leading-relaxed">
                    <%- c.body %>
                </p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- The Problem Section -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-30"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 bottom-0 right-0 opacity-20"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="animate-on-scroll glass rounded-3xl p-12 border border-indigo-500/20">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-indigo-600 mb-6 shadow-glow-indigo">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                </div>
                <h2 class="text-3xl font-bold text-white mb-4"><%= t.problem.h2 %></h2>
            </div>

            <div class="text-gray-400 text-lg leading-relaxed space-y-4">
                <p>
                    <%- t.problem.body %>
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Our Commitment Section -->
<section class="section--sm relative overflow-hidden bg-gradient-to-b from-surface-primary to-surface-secondary">
    <div class="absolute inset-0 grid-pattern opacity-40"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-30"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="animate-on-scroll">
            <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">
                <%= t.commitment.h2Before %> <span class="text-gradient-green pb-1 leading-relaxed"><%= t.commitment.h2Accent %></span>
            </h2>

            <p class="text-xl text-gray-400 mb-8 max-w-3xl mx-auto leading-relaxed">
                <%- t.commitment.subtitle %>
            </p>

            <div class="inline-flex flex-col gap-3 text-lg text-gray-300 text-left">
                <% t.commitment.bullets.forEach(function (b) { %>
                <div class="flex items-center gap-3">
                    <svg class="w-6 h-6 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span><%= b %></span>
                </div>
                <% }); %>
            </div>

            <div class="mt-12 p-8 glass rounded-2xl inline-block">
                <p class="text-2xl font-bold text-gradient-indigo pb-1 leading-relaxed">
                    <%= t.commitment.quote %>
                </p>
            </div>

            <div class="mt-12">
                <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group" onclick="trackEvent('CTA', 'Click', 'Get Started')">
                    <%= t.commitment.ctaPrimary %>
                    <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>

<%- include('./includes/_footer.ejs') %>

<script>
// Scroll animation observer
document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver(function(entries) {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.animate-on-scroll').forEach(el => {
        observer.observe(el);
    });

    // Card glow effect on mouse move
    document.querySelectorAll('.card--glow').forEach(card => {
        card.addEventListener('mousemove', function(e) {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            card.style.setProperty('--mouse-x', `${x}px`);
            card.style.setProperty('--mouse-y', `${y}px`);
        });
    });
});
</script>

</body>
</html>
