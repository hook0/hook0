<%
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('data-processing-addendum', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
    <style>
        .legal-table {
            width: 100%;
            border-collapse: collapse;
            margin: 1.5rem 0;
        }
        .legal-table th,
        .legal-table td {
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem;
            text-align: left;
        }
        .legal-table th {
            background-color: rgba(99, 102, 241, 0.2);
            color: white;
            font-weight: 600;
            width: 35%;
        }
        .legal-table td {
            background-color: rgba(255, 255, 255, 0.02);
            color: #d1d5db;
        }
        .legal-content h2 {
            color: white;
            font-size: 1.5rem;
            font-weight: 700;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
        }
        .legal-content h3 {
            color: white;
            font-size: 1.25rem;
            font-weight: 600;
            margin-top: 2rem;
            margin-bottom: 0.75rem;
        }
        .legal-content p {
            color: #d1d5db;
            line-height: 1.75;
            margin-bottom: 1rem;
        }
        .legal-content ol,
        .legal-content ul {
            color: #d1d5db;
            margin-left: 1.5rem;
            margin-bottom: 1rem;
        }
        .legal-content li {
            margin-bottom: 0.5rem;
            line-height: 1.75;
        }
        .legal-content a {
            color: #4ade80;
            transition: color 0.2s;
        }
        .legal-content a:hover {
            color: #86efac;
        }
    </style>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-24">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.title %>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>
        <div class="mt-4 inline-flex items-center px-4 py-2 rounded-full bg-white/10 text-sm text-gray-300">
            <svg class="w-4 h-4 mr-2 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <%= t.hero.lastUpdatedLabel %> <%= t.hero.lastUpdatedDate %>
        </div>
    </div>
</section>

<!-- Main Content Section -->
<section class="relative bg-surface-primary py-16 sm:py-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-20"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="card card--glow">
            <div class="legal-content">

                <h2><%= t.preamble.title %></h2>

                <p><%- t.preamble.partiesHtml %></p>

                <p><%= t.preamble.p1 %></p>

                <p><%= t.preamble.p2 %></p>

                <p><%= t.preamble.p3 %></p>

                <h2><%= t.section1.title %></h2>

                <p><%= t.section1.p1 %></p>

                <p><%= t.section1.p2 %></p>

                <h2><%= t.section2.title %></h2>

                <p><%= t.section2.p1 %></p>

                <ul>
                    <% t.section2.items.forEach(function (it) { %>
                    <li><%- it %></li>
                    <% }); %>
                </ul>

                <p><%= t.section2.p2 %></p>

                <p><%= t.section2.p3 %></p>

                <p><%= t.section2.p4 %></p>

                <p><%= t.section2.p5 %></p>

                <p><%= t.section2.p6 %></p>

                <h2><%= t.section3.title %></h2>

                <p><%= t.section3.p1 %></p>

                <ol>
                    <% t.section3.items.forEach(function (it) { %>
                    <li><%- it %></li>
                    <% }); %>
                </ol>

                <h2><%= t.section4.title %></h2>

                <p><%= t.section4.p1 %></p>

                <p><%= t.section4.p2 %></p>

                <h2><%= t.section5.title %></h2>

                <p><%- t.section5.p1Html %></p>

                <p><%- t.section5.p2Html %></p>

                <p><%= t.section5.p3 %></p>

                <p><%= t.section5.p4 %></p>

                <h2><%= t.section6.title %></h2>

                <p><%- t.section6.p1Html %></p>

                <p><%- t.section6.p2Html %></p>

                <p><%= t.section6.p3 %></p>

                <p><%= t.section6.p4 %></p>

                <h2><%= t.section7.title %></h2>

                <p><%= t.section7.p1 %></p>

                <p><%= t.section7.p2 %></p>

                <ol>
                    <% t.section7.items.forEach(function (it) { %>
                    <li><%- it %></li>
                    <% }); %>
                </ol>

                <h2><%= t.section8.title %></h2>

                <p><%- t.section8.p1Html %></p>

                <ol>
                    <% t.section8.items.forEach(function (it) { %>
                    <li><%- it %></li>
                    <% }); %>
                </ol>

                <p><%= t.section8.p2 %></p>

                <p><%= t.section8.p3 %></p>

                <h2><%= t.section9.title %></h2>

                <p><%= t.section9.p1 %></p>

                <ol>
                    <% t.section9.items.forEach(function (it) { %>
                    <li><%- it %></li>
                    <% }); %>
                </ol>

                <h2><%= t.section10.title %></h2>

                <p><%= t.section10.p1 %></p>

                <h2><%= t.section11.title %></h2>

                <p><%= t.section11.p1 %></p>

                <p><%= t.section11.p2 %></p>

                <ol>
                    <% t.section11.items.forEach(function (it) { %>
                    <li><%- it %></li>
                    <% }); %>
                </ol>

                <h2><%= t.section12.title %></h2>

                <p><%= t.section12.p1 %></p>

                <p><%= t.section12.p2 %></p>

                <p><%= t.section12.p3 %></p>

                <p><%= t.section12.p4 %></p>

                <p><%= t.section12.p5 %></p>

                <p><%= t.section12.p6 %></p>

                <p><%= t.section12.p7 %></p>

                <h2><%= t.appendix1.title %></h2>

                <table class="legal-table">
                    <% t.appendix1.rows.forEach(function (r) { %>
                    <tr>
                        <th><%= r.label %></th>
                        <td><%- r.valueHtml %></td>
                    </tr>
                    <% }); %>
                </table>

                <h2><%= t.appendix2.title %></h2>

                <p><%= t.appendix2.intro %></p>

                <% t.appendix2.groups.forEach(function (g) { %>
                <h3><%= g.title %></h3>
                <ul>
                    <% g.items.forEach(function (it) { %>
                    <li><%- it %></li>
                    <% }); %>
                </ul>
                <% if (g.noteHtml) { %>
                <p><%- g.noteHtml %></p>
                <% } %>
                <% }); %>

            </div>
        </div>
    </div>
</section>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
