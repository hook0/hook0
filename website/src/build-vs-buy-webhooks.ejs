<%
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('build-vs-buy-webhooks', locals.lang || 'en')); }
var t = locals.t;
var getPath = (locals.i18nHelpers && locals.i18nHelpers.getPath) ? locals.i18nHelpers.getPath : function (s) { return './' + s; };
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative gradient-hero overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="section__eyebrow"><%= t.hero.eyebrow %></span>
        <h1 class="mt-4 text-display-xl text-white">
            <%= t.hero.titleBefore %>
            <span class="block text-gradient-green"><%= t.hero.titleAccent %></span>
        </h1>
        <p class="mt-6 text-body-lg text-gray-400 max-w-2xl mx-auto">
            <%= t.hero.subtitle %>
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group" onclick="trackEvent('CTA', 'Click', 'build-vs-buy-hero-register')">
                <%= t.hero.ctaPrimary %>
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </a>
            <a href="https://play.hook0.com" target="_blank" rel="noopener" class="btn btn--secondary btn--lg" onclick="trackEvent('CTA', 'Click', 'build-vs-buy-hero-playground')">
                <%= t.hero.ctaSecondary %>
            </a>
        </div>

        <!-- Quick Stats -->
        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto animate-on-scroll stagger-children">
            <% t.hero.stats.forEach(function (s) { %>
            <div class="glass rounded-2xl p-6">
                <div class="text-3xl font-extrabold text-gradient-<%= s.color %> mb-2 pb-1 leading-relaxed"><%= s.value %></div>
                <div class="text-sm text-gray-400"><%= s.label %></div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<%- include('./includes/_social-proof-bar.ejs') %>

<!-- Hidden Costs of DIY -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 top-1/4 right-0 opacity-10"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.hiddenCosts.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.hiddenCosts.h2 %></h2>
            <p class="mt-4 text-body-lg text-gray-400 max-w-2xl mx-auto">
                <%= t.hiddenCosts.sub %>
            </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
            <% var __costIcons = [
              'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
              'M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4',
              'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
              'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
              'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
            ]; %>
            <% t.hiddenCosts.cards.forEach(function (c, i) { var iconPath = __costIcons[i] || __costIcons[0]; %>
            <div class="animate-on-scroll card card--glow p-6">
                <div class="w-10 h-10 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center mb-4">
                    <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= iconPath %>"></path>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2"><%= c.title %></h3>
                <p class="text-sm text-gray-400"><%= c.body %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Build vs Buy Comparison -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.comparison.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.comparison.h2 %></h2>
        </div>

        <div class="animate-on-scroll overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="py-4 px-6 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= t.comparison.headers.aspect %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-red-400 uppercase tracking-wider"><%= t.comparison.headers.diy %></th>
                        <th class="py-4 px-6 text-sm font-semibold text-green-400 uppercase tracking-wider"><%= t.comparison.headers.hook0 %></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% t.comparison.rows.forEach(function (r) { %>
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="py-4 px-6 text-gray-300"><%= r.aspect %></td>
                        <td class="py-4 px-6 <%= r.diyDim ? 'text-gray-400' : 'text-red-400' %>"><%- r.diyHtml %></td>
                        <td class="py-4 px-6 text-green-400 font-medium"><%- r.hook0Html %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Integration Speed -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="blur-circle blur-circle--green w-64 h-64 bottom-1/4 left-0 opacity-10"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.integration.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.integration.h2 %></h2>
            <p class="mt-4 text-body-lg text-gray-400"><%= t.integration.sub %></p>
        </div>

        <div class="animate-on-scroll card card--glow p-8">
            <pre class="text-sm text-gray-300 overflow-x-auto"><code><%= t.integration.codeBlock %></code></pre>
            <p class="mt-4 text-sm text-gray-500"><%= t.integration.codeFootnote %></p>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="section relative overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-20"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 animate-on-scroll">
            <span class="section__eyebrow"><%= t.faq.eyebrow %></span>
            <h2 class="mt-4 text-display font-bold text-white"><%= t.faq.h2 %></h2>
        </div>

        <div class="space-y-6 stagger-children">
            <% t.faq.items.forEach(function (item) { %>
            <div class="animate-on-scroll card card--glow p-6">
                <h3 class="text-lg font-semibold text-white mb-2"><%= item.q %></h3>
                <p class="text-gray-400"><%= item.a %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Deep Dive Link -->
<section class="py-12 relative">
    <div class="container mx-auto px-6 text-center">
        <p class="text-gray-400"><%- t.deepDiveHtml %></p>
    </div>
</section>

<!-- Related Pages -->
<section class="py-12 relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-lg font-semibold text-gray-400 mb-6 text-center"><%= t.related.h2 %></h2>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
            <% t.related.links.forEach(function (link) { %>
            <a href="<%= getPath(link.enSlug, locals.pageLang) %>" class="text-indigo-400 hover:text-indigo-300 underline"><%= link.label %></a>
            <% }); %>
        </div>
    </div>
</section>

<!-- CTA Section -->
<%- include('./includes/_cta-inline.ejs') %>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
