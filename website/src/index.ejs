<%
if (locals.i18nHelpers) { Object.assign(locals, locals.i18nHelpers.getPageLocals('index', locals.lang || 'en')); }
var t = locals.t;
%><!DOCTYPE html>
<html lang="<%= locals.pageLang %>">
<head>
    <title><%= locals.pageTitle %></title>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
  <a name="top"></a>

<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center gradient-hero overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 bottom-20 left-1/4 opacity-30"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
            <!-- Left Column - Text Content -->
            <div class="text-center lg:text-left">
                <!-- Badge -->
                <a href="<%= locals.social.github.href %>"
                   class="animate-on-scroll inline-flex items-center gap-3 px-1 pr-4 py-1 rounded-full
                          bg-white/5 border border-white/10 backdrop-blur-sm
                          hover:bg-white/10 transition-all duration-300 group">
                    <span class="px-3 py-1 text-xs font-semibold tracking-wide bg-green-500 text-white rounded-full">
                        <%= t.hero.badgePillBootstrapped %>
                    </span>
                    <span class="text-sm text-gray-300 group-hover:text-white transition-colors">
                        <%= t.hero.badgeOpenSource %>
                    </span>
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-white group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </a>

                <!-- Headline -->
                <h1 class="animate-on-scroll mt-8 text-display-xl text-white">
                    <span class="block"><%= t.hero.headlineLine1 %></span>
                    <span class="block text-gradient-green"><%= t.hero.headlineLine2 %></span>
                </h1>

                <!-- Description -->
                <p class="animate-on-scroll mt-6 text-body-lg text-gray-400 max-w-xl mx-auto lg:mx-0">
                    <%= t.hero.description %>
                </p>

                <!-- CTA Buttons -->
                <div class="animate-on-scroll mt-10 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                    <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group whitespace-nowrap" onclick="trackEvent('CTA', 'Click', 'Start Free')">
                        <%= t.hero.ctaPrimary %>
                        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                        </svg>
                    </a>
                    <a href="https://documentation.hook0.com/tutorials/getting-started" class="btn btn--secondary btn--lg whitespace-nowrap" onclick="trackEvent('CTA', 'Click', 'hero-quick-start')">
                        <%= t.hero.ctaSecondary %>
                    </a>
                </div>

                <!-- Trust Indicators -->
                <div class="animate-on-scroll mt-10 flex flex-wrap gap-6 justify-center lg:justify-start text-sm text-gray-400">
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span><%= t.hero.trustFreePlan %></span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span><%= t.hero.trustNoCard %></span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span class="inline-flex items-center gap-1.5">
                            <%= t.hero.trustHostedEurope %>
                            <%- include('./svg/europe-flag.svg') %>
                        </span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                        <span><%= t.hero.trustGdpr %></span>
                    </div>
                </div>

                <!-- Social Proof -->
                <div class="animate-on-scroll mt-10 pt-8 border-t border-white/10">
                    <div class="flex flex-col sm:flex-row items-center gap-6 justify-center lg:justify-start">
                        <a href="https://www.producthunt.com/posts/hook0?utm_source=badge-top-post-badge&utm_medium=badge&utm_souce=badge-hook0" target="_blank" rel="noopener noreferrer" class="opacity-80 hover:opacity-100 transition-opacity">
                            <img src="https://api.producthunt.com/widgets/embed-image/v1/top-post-badge.svg?post_id=447944&theme=neutral&period=daily" alt="<%= t.hero.socialProductHuntAlt %>" width="240" height="54" loading="lazy" />
                        </a>
                        <div class="flex items-center gap-4">
                            <a href="<%= locals.social.github.repoHref %>" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors"
                               title="<%= t.hero.socialGithubStars %>">
                                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                                <span class="text-sm font-medium text-white"><% if (locals.social.github.stars) { %><%= locals.social.github.stars.toLocaleString('en-US') %> <% } %><%= t.hero.socialGithubStars %></span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Webhook Flow Illustration -->
            <div class="hidden lg:block relative mt-16 lg:mt-0">
                <div class="animate-on-scroll animate-on-scroll--right">
                    <div class="relative">
                        <!-- Glow effect behind illustration -->
                        <div class="absolute inset-0 bg-green-500/10 blur-3xl rounded-full scale-90"></div>
                        <div class="relative w-full max-w-xl">
                            <%- include('./svg/webhook-flow-illustration.svg') %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <a href="#customers" class="flex flex-col items-center gap-2 text-gray-500 hover:text-white transition-colors">
            <span class="text-xs uppercase tracking-wider"><%= t.hero.scrollLabel %></span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
        </a>
    </div>
</section>

<%- include('./includes/_customers.ejs') %>

<a name="how-it-works"></a>

<%- include('./includes/_how-it-works') %>

<%- include('./includes/_features.ejs') %>

<%- include('./includes/_testimonials.ejs') %>

<%- include('./includes/_cta-inline.ejs') %>

<%- include('./includes/_built-to-last.ejs') %>

<%- include('./includes/_use-case.ejs') %>

<%- include('./includes/_api-and-doc.ejs') %>

<a name="pricing" id="pricing"></a>
<%- include('./includes/_pricing.ejs') %>

<%- include('./includes/_faq.ejs') %>

<!-- Explore More - Internal Navigation for Exit-Intent -->
<section class="relative py-16 overflow-hidden">
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
            <h2 class="text-xl font-semibold text-white"><%= t.goDeeper.h2 %></h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <% var __gdIcons = {
              'green': 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
              'indigo': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
              'yellow': 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
              'purple': 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
              'pink': 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
              'emerald': 'M13 10V3L4 14h7v7l9-11h-7z',
            }; %>
            <% t.goDeeper.cards.forEach(function(card) { %>
            <a href="<%= card.href %>"<% if (card.external) { %> target="_blank" rel="noopener"<% } %> class="group p-5 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-center" onclick="trackEvent('Navigation', 'Click', 'Explore <%= card.label %>')">
                <svg class="w-6 h-6 mx-auto text-<%= card.color %>-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= __gdIcons[card.color] %>"></path></svg>
                <span class="text-sm text-gray-300 group-hover:text-white transition-colors"><%= card.label %></span>
            </a>
            <% }) %>
        </div>
    </div>
</section>

<%- include('./includes/_footer.ejs') %>

</body>
</html>
