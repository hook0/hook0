<!DOCTYPE html>
<html lang="en">
<head>
    <title>Hook0 — Free Open-Source Webhook Platform | Webhooks as a Service</title>
    <%
    locals.pageTitle = 'Hook0 — Free Open-Source Webhook Platform | Webhooks as a Service';
    locals.pageDescription = 'Free webhook platform, open-source. Send webhooks with one API call — Hook0 handles retries, HMAC signatures, and delivery monitoring. Free forever, no credit card. Self-host or use our cloud.';
    locals.pageCanonical = '/';
    locals.pageSchema = {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Hook0",
          "url": locals.seo.siteUrl,
          "logo": locals.seo.siteUrl + "/mediakit/logo/110x110-white.png",
          "description": locals.seo.defaultDescription,
          "foundingDate": "2021",
          "founders": [
            { "@type": "Person", "name": "Francois-Guillaume Ribreau" },
            { "@type": "Person", "name": "David Sferruzza" }
          ],
          "sameAs": [
            locals.social.twitter.href,
            locals.social.github.href,
            locals.social.linkedin.href,
            locals.social.youtube.href,
            locals.social.discord.href
          ],
          "contactPoint": {
            "@type": "ContactPoint",
            "email": "support@hook0.com",
            "contactType": "customer service"
          }
        },
        {
          "@type": "SoftwareApplication",
          "name": "Hook0",
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "Any",
          "url": locals.seo.siteUrl,
          "description": "Open-source webhook infrastructure. Send webhooks with one API call — retries, HMAC signatures, and delivery monitoring included.",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD",
            "description": "Free tier: 100 webhook events/day, HMAC signatures, delivery monitoring. No credit card required."
          },
          "author": {
            "@type": "Organization",
            "name": "Hook0"
          },
          "license": "https://opensource.org/licenses/SSPL-1.0",
          "downloadUrl": locals.social.github.repoHref,
          "softwareVersion": "2026",
          "featureList": "Webhook delivery, HMAC signatures, Configurable retries, Delivery monitoring, Subscriber portal, Self-hosting, REST API, SDKs"
        }
      ]
    };
    locals.pageFAQSchema = {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Does Hook0 have a free tier?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Hook0 has a free tier that includes 100 webhook events per day, HMAC signatures, and delivery monitoring. No credit card required. Hook0 is also fully open-source — you can self-host it at no cost."
          }
        },
        {
          "@type": "Question",
          "name": "What is webhooks as a service?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Webhooks as a service means you send events to Hook0 via a REST API, and Hook0 delivers them to your users' endpoints. It handles retries, cryptographic signatures, delivery logging, and subscriber management so you don't have to build that infrastructure yourself."
          }
        },
        {
          "@type": "Question",
          "name": "Is Hook0 open-source?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The source code is available on GitHub and GitLab under the SSPL-1.0 license (client SDKs are MIT). You can self-host it with Docker Compose or Kubernetes, or use the managed cloud service hosted in Europe."
          }
        },
        {
          "@type": "Question",
          "name": "Can I self-host Hook0?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Hook0 supports self-hosting via Docker Compose or Kubernetes. The self-hosted version has the same features as the cloud version. Documentation is at documentation.hook0.com/self-hosting."
          }
        },
        {
          "@type": "Question",
          "name": "How does Hook0 compare to Svix, Hookdeck, or HostedHooks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hook0 is the only fully open-source option with self-hosting support. Unlike Svix (open-core), Hook0 has no proprietary enterprise tier. Compared to Hookdeck (webhook gateway) and HostedHooks (closed-source SaaS), Hook0 is bootstrapped with no VC funding and offers both cloud and on-premise deployment."
          }
        }
      ]
    };
    %>
    <%- include('./includes/_head.ejs') %>
</head>
<body>
  <a name="top"></a>

<%- include('./includes/_header.ejs') %>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center gradient-hero overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>
    <div class="blur-circle blur-circle--indigo w-96 h-96 -top-48 -left-48"></div>
    <div class="blur-circle blur-circle--green w-80 h-80 top-1/2 -right-40"></div>
    <div class="blur-circle blur-circle--indigo w-64 h-64 bottom-20 left-1/4 opacity-30"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
            <!-- Left Column - Text Content -->
            <div class="text-center lg:text-left">
                <!-- Badge -->
                <a href="<%= locals.social.github.href %>"
                   class="animate-on-scroll inline-flex items-center gap-3 px-1 pr-4 py-1 rounded-full
                          bg-white/5 border border-white/10 backdrop-blur-sm
                          hover:bg-white/10 transition-all duration-300 group">
                    <span class="px-3 py-1 text-xs font-semibold tracking-wide bg-green-500 text-white rounded-full">
                        100% Bootstrapped
                    </span>
                    <span class="text-sm text-gray-300 group-hover:text-white transition-colors">
                        Hook0 is Open-Source
                    </span>
                    <svg class="w-4 h-4 text-gray-400 group-hover:text-white group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </a>

                <!-- Headline -->
                <h1 class="animate-on-scroll mt-8 text-display-xl text-white">
                    <span class="block">Webhooks</span>
                    <span class="block text-gradient-green">As A Service</span>
                </h1>

                <!-- Description -->
                <p class="animate-on-scroll mt-6 text-body-lg text-gray-400 max-w-xl mx-auto lg:mx-0">
                    Hook0 is an Open-Source Webhooks-as-a-service (WaaS) that makes it easy for developers to send webhooks. Developers make one API call, and Hook0 takes care of deliverability, retries, security, and more.
                </p>

                <!-- CTA Buttons -->
                <div class="animate-on-scroll mt-10 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                    <a href="https://app.hook0.com/register" class="btn btn--primary btn--lg group whitespace-nowrap" onclick="trackEvent('CTA', 'Click', 'Start Free')">
                        Start Free
                        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                        </svg>
                    </a>
                    <a href="https://documentation.hook0.com/tutorials/getting-started" class="btn btn--secondary btn--lg whitespace-nowrap" onclick="trackEvent('CTA', 'Click', 'hero-quick-start')">
                        Quick Start Guide
                    </a>
                </div>

                <!-- Trust Indicators -->
                <div class="animate-on-scroll mt-10 flex flex-wrap gap-6 justify-center lg:justify-start text-sm text-gray-400">
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Free Plan</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>No Credit Card</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span class="inline-flex items-center gap-1.5">
                            Hosted in Europe
                            <%- include('./svg/europe-flag.svg') %>
                        </span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                        <span>GDPR Compliant</span>
                    </div>
                </div>

                <!-- Social Proof -->
                <div class="animate-on-scroll mt-10 pt-8 border-t border-white/10">
                    <div class="flex flex-col sm:flex-row items-center gap-6 justify-center lg:justify-start">
                        <a href="https://www.producthunt.com/posts/hook0?utm_source=badge-top-post-badge&utm_medium=badge&utm_souce=badge-hook0" target="_blank" class="opacity-80 hover:opacity-100 transition-opacity">
                            <img src="https://api.producthunt.com/widgets/embed-image/v1/top-post-badge.svg?post_id=447944&theme=neutral&period=daily" alt="Hook0 on Product Hunt" width="240" height="54" loading="lazy" />
                        </a>
                        <div class="flex items-center gap-4">
                            <iframe src="https://ghbtns.com/github-btn.html?user=hook0&repo=hook0&type=star&count=true&size=large" frameborder="0" scrolling="0" width="170" height="30" title="GitHub Stars" loading="lazy"></iframe>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Webhook Flow Illustration -->
            <div class="hidden lg:block relative mt-16 lg:mt-0">
                <div class="animate-on-scroll animate-on-scroll--right">
                    <div class="relative">
                        <!-- Glow effect behind illustration -->
                        <div class="absolute inset-0 bg-green-500/10 blur-3xl rounded-full scale-90"></div>
                        <div class="relative w-full max-w-xl">
                            <%- include('./svg/webhook-flow-illustration.svg') %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <a href="#customers" class="flex flex-col items-center gap-2 text-gray-500 hover:text-white transition-colors">
            <span class="text-xs uppercase tracking-wider">Scroll</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
        </a>
    </div>
</section>

<%- include('./includes/_customers.ejs') %>

