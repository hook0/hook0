            <h2 class="text-xl font-semibold text-white">Go deeper</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a href="./built-to-last" class="group p-5 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-center" onclick="trackEvent('Navigation', 'Click', 'Explore Built to Last')">
                <svg class="w-6 h-6 mx-auto text-green-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
