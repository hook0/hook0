            <a href="./security" class="group p-5 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-center" onclick="trackEvent('Navigation', 'Click', 'Explore Security')">
                <svg class="w-6 h-6 mx-auto text-indigo-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
