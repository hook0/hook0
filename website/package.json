{
  "name": "website",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://www.hook0.com/",
  "private": true,
  "scripts": {
    "preinstall": "rm -rf ./src/mediakit; cp -R -v $(pwd)/../mediakit ./src/mediakit && cp -v ./src/mediakit/logo/favicon.ico static/favicon.ico && rm -rf ./static/mediakit && cp -R $(pwd)/../mediakit ./static/mediakit && npm run --silent update:oss-friends",
    "postinstall": "node scripts/optimize-images.js || true",
    "update:oss-friends": "curl https://formbricks.com/api/oss-friends > ./oss-friends.json",
    "update:github-stars": "node scripts/fetch-github-stars.js",
    "serve": "npx nodemon -w ./data.js -w ./locales -w ./src -i dist/ -i temp/ --ext .js,.json,.ejs --exec 'npm run build:dev && npx serve dist'",
    "build:i18n:compile": "cd scripts/build-i18n && cargo build --release",
    "build:i18n-gate:compile": "cd scripts/i18n-gate && cargo build --release",
    "build:dev": "npm run update:github-stars && npm run build:i18n:compile && ./scripts/build-i18n/target/release/build-i18n",
    "build": "npm run update:github-stars && npm run build:i18n:compile && ./scripts/build-i18n/target/release/build-i18n",
    "build:local": "LOCAL_PREVIEW_URL=http://localhost:4000 npm run build",
    "serve:local": "npx serve dist -l 4000 --no-clipboard",
    "check:i18n": "npm run build:i18n-gate:compile && ./scripts/i18n-gate/target/release/i18n-gate"
  },
  "contributors": [
    "Francois-Guillaume Ribreau <npm@fgribreau.com> (http://fgribreau.com/)",
    "David Sferruzza <david@hook0.com> (https://david.sferruzza.fr)"
  ],
  "license": "MIT",
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.16.3",
    "@parcel/transformer-jsonld": "^2.16.3",
    "@parcel/transformer-sass": "^2.9.3",
    "@parcel/transformer-webmanifest": "^2.16.3",
    "@tailwindcss/typography": "^0.5.0",
    "nodemon": "^3.0.1",
    "parcel": "^2.9.3",
    "parcel-reporter-static-files-copy": "^1.4.0",
    "parcel-transformer-ejs": "^1.0.0",
    "postcss": "^8.3.11",
    "postcss-100vh-fix": "^2.0.0",
    "postcss-import": "^16.0.0",
    "prettier": "^3.0.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.0.1"
  },
  "volta": {
    "node": "18.17.1"
  },
  "dependencies": {
    "@parcel/reporter-dev-server": "^2.16.4",
    "msgpackr": "^1.11.12"
  },
  "overrides": {
    "msgpackr": "^1.11.12",
    "@parcel/reporter-dev-server": "^2.16.4"
  }
}
