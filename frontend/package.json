{
  "name": "hook0",
  "version": "2.0.0",
  "description": "Hook0 Frontend - Webhook As a Service",
  "contributors": [
    "Francois-Guillaume Ribreau <npm@fgribreau.com> (http://fgribreau.com/)",
    "David Sferruzza <david@hook0.com>"
  ],
  "private": true,
  "license": "SSPL-1.0",
  "type": "module",
  "files": [
    "src/**",
    "public/**",
    "README.md",
    "LICENSE.txt",
    "tsconfig.json"
  ],
  "scripts": {
    "preinstall": "cp -v ../mediakit/logo/favicon.ico ./public/favicon.ico && cp -v ../mediakit/logo/256x256.png ./public/256x256.png && cp -v ../mediakit/logo-scripts/raw.svg ./public/logo.svg",
    "//start:dev": "don't forget to first start the Rust API in order to then access to this frontend through the API http server",
    "build": "vite build",
    "dev": "vite",
    "check": "tsc --noEmit && vue-tsc --noEmit",
    "lint": "eslint --ext .js,.ts,.vue --ignore-path .gitignore --fix ./src",
    "test": "jest --watchAll=false --maxWorkers=50%",
    "test:watch": "jest --maxWorkers=25%",
    "test:ci": "jest --runInBand --coverage --collectCoverage",
    "format": "prettier --write src/ ./*.{js,ts,json}",
    "generate:types": "openapi-typescript http://localhost:8080/api/v1/swagger.json --output src/types.ts && npm run --silent format",
    "generate:types:prod": "openapi-typescript https://app.hook0.com/api/v1/swagger.json --output src/types.ts && npm run --silent format"
  },
  "dependencies": {
    "@biscuit-auth/biscuit-wasm": "^0.6.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@formbricks/js": "^4.2.1",
    "@tanstack/vue-query": "^5.92.6",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.1.0",
    "@vueuse/motion": "^3.0.3",
    "axios": "^1.2.2",
    "codemirror": "^6.0.1",
    "crisp-sdk-web": "^1.0.21",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "lucide-vue-next": "^0.562.0",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.26",
    "vue-codemirror": "^6.1.1",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.2.8",
    "vue-matomo": "^4.2.0",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "vue-turnstile": "^1.0.11",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.16.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/jest": "^30.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^13.0.0",
    "eslint": "^8.4.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier-vue": "^5.0.0",
    "eslint-plugin-vue": "^9.7.0",
    "jest": "^30.1.3",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.3.2",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.1.1",
    "typescript": "5.6.*",
    "vite": "^8.0.0",
    "vite-plugin-checker": "^0.9.1",
    "vite-plugin-wasm": "^3.6.0",
    "vue-tsc": "^2.2.8"
  },
  "keywords": [
    "webhook",
    "webhooks",
    "web-hook",
    "connectors",
    "api",
    "webhook api",
    "webhook server"
  ],
  "volta": {
    "node": "20.19.0"
  }
}
